        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Доступ до локальної мережі потрібен для виявлення пристроїв і передавання файлів через вашу Wi-Fi мережу."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cần quyền truy cập mạng nội bộ để phát hiện thiết bị và truyền tệp qua mạng Wi-Fi của bạn."
