    "NSPhotoLibraryAddUsageDescription" : {
      "comment" : "Privacy - Photo Library Additions Usage Description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "إذن الوصول إلى مكتبة الصور مطلوب لحفظ الصور والفيديوهات المستلمة في مكتبتك."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Es necessita permís a la biblioteca de fotos per desar les fotos i vídeos rebuts a la teva biblioteca."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Oprávnění k fotkám je potřeba pro ukládání přijatých fotek a videí do vaší knihovny."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Tilladelse til fotobibliotek er nødvendig for at gemme modtagne fotos og videoer i dit fotobibliotek."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Die Berechtigung für die Fotomediathek wird benötigt, um empfangene Fotos und Videos in deiner Mediathek zu speichern."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Η άδεια πρόσβασης στη βιβλιοθήκη φωτογραφιών απαιτείται για να αποθηκεύετε ληφθείσες φωτογραφίες και βίντεο στη βιβλιοθήκη σας."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "The add photos permission is required to save received photos and videos to your photo library."
          }
        },
        "en-AU" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "The photo library permission is required to save received photos and videos to your photo library."
          }
        },
        "en-CA" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Permission to access your photo library is needed to save received photos and videos to your photo library."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "The photo library permission is required to save received photos and videos to your photo library."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Se necesita permiso para la biblioteca de fotos para guardar las fotos y videos recibidos en tu galería."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Se requiere el permiso para acceder a la fototeca para guardar las fotos y videos recibidos en tu biblioteca."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Valokuvakirjaston käyttöoikeus tarvitaan, jotta vastaanotetut kuvat ja videot voidaan tallentaa kirjastoon."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "L’accès à la photothèque est nécessaire pour enregistrer les photos et vidéos reçues dans votre photothèque."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "L'autorisation d’accès à la photothèque est requise pour enregistrer les photos et vidéos reçues dans votre photothèque."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "נדרש אישור לספריית התמונות כדי לשמור תמונות וסרטונים שהתקבלו בספריית התמונות שלך."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "प्राप्त फ़ोटो और वीडियो को आपकी फोटो लाइब्रेरी में सहेजने के लिए फोटो लाइब्रेरी अनुमति आवश्यक है।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Dozvola za pristup galeriji potrebna je za spremanje primljenih fotografija i videozapisa u vašu galeriju."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "A fotókönyvtár engedélye szükséges a fogadott fotók és videók mentéséhez a fotókönyvtárba."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Izin akses galeri foto diperlukan untuk menyimpan foto dan video yang diterima ke galeri Anda."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Il permesso alla libreria foto è necessario per salvare le foto e i video ricevuti nella tua libreria."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "受信した写真や動画をフォトライブラリに保存するには、フォトライブラリの権限が必要です。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "수신한 사진과 동영상을 사진 보관함에 저장하려면 사진 보관함 권한이 필요합니다."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Kebenaran pustaka foto diperlukan untuk menyimpan foto dan video yang diterima ke pustaka foto anda."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Tillatelse til bildebibliotek kreves for å lagre mottatte bilder og videoer i bildebiblioteket ditt."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Toestemming voor de fotobibliotheek is vereist om ontvangen foto’s en video’s op te slaan in je fotobibliotheek."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Uprawnienia do galerii zdjęć są wymagane, aby zapisywać odebrane zdjęcia i filmy w Twojej bibliotece."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "A permissão da biblioteca de fotos é necessária para salvar fotos e vídeos recebidos na sua galeria."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "A permissão para a fototeca é necessária para guardar as fotos e vídeos recebidos na sua fototeca."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Permisiunea pentru biblioteca foto este necesară pentru a salva fotografii și videoclipuri primite în biblioteca ta foto."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Для сохранения полученных фото и видео в фотогалерею требуется доступ к медиатеке."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Behörighet till bildbiblioteket krävs för att spara mottagna foton och videor till ditt bildbibliotek."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "จำเป็นต้องขออนุญาตเข้าถึงคลังภาพเพื่อบันทึกรูปภาพและวิดีโอที่ได้รับไปยังคลังภาพของคุณ"
          }
        },
