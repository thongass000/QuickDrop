    "SaveToPhotosErrorPermissionDenied" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "variations" : {
            "device" : {
              "mac" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "لقد منعت QuickDrop من حفظ المحتوى في معرض الصور لديك. لتغيير ذلك، افتح إعدادات النظام ثم انتقل إلى \"الخصوصية والأمان\" > \"الصور\"، وفعّل خيار QuickDrop."
                }
              },
              "other" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "لقد منعت QuickDrop من حفظ المحتوى في معرض الصور لديك. لتغيير ذلك، افتح تطبيق الإعدادات، وابحث عن \"QuickDrop\"، ثم غيّر إعداد \"الصور\" إلى \"إضافة الصور فقط\"."
                }
              }
            }
          }
        },
        "ca" : {
          "variations" : {
            "device" : {
              "mac" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "Has denegat a QuickDrop l'accés per desar contingut a la teva galeria. Per canviar-ho, obre la configuració del sistema, ves a «Privacitat i seguretat» > «Fotos» i activa l'opció per a QuickDrop."
                }
              },
              "other" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "Has denegat a QuickDrop l'accés per desar contingut a la teva galeria. Per canviar-ho, obre l'app de configuració, busca \"QuickDrop\" i canvia l'opció «Fotos» a «Només afegir fotos»."
                }
              }
            }
          }
        },
        "cs" : {
          "variations" : {
            "device" : {
              "mac" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "Odepřeli jste aplikaci QuickDrop přístup k ukládání obsahu do vaší galerie. Chcete-li to změnit, otevřete Systémová nastavení, přejděte na „Soukromí a zabezpečení“ > „Fotky“ a povolte přepínač pro QuickDrop."
                }
              },
              "other" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "Odepřeli jste aplikaci QuickDrop přístup k ukládání obsahu do vaší galerie. Chcete-li to změnit, otevřete aplikaci Nastavení, vyhledejte „QuickDrop“ a nastavte možnost „Fotky“ na „Přidat pouze fotky“."
                }
              }
            }
          }
        },
        "da" : {
          "variations" : {
            "device" : {
              "mac" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "Du har nægtet QuickDrop adgang til at gemme indhold i dit galleri. For at ændre dette skal du åbne Systemindstillinger, gå til \"Privatliv & sikkerhed\" > \"Billeder\", og aktivere QuickDrop."
                }
              },
              "other" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "Du har nægtet QuickDrop adgang til at gemme indhold i dit galleri. For at ændre dette skal du åbne Indstillinger, søge efter \"QuickDrop\" og sætte \"Billeder\" til \"Kun tilføj billeder\"."
                }
              }
            }
          }
        },
        "de" : {
          "variations" : {
            "device" : {
              "mac" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "Du hast QuickDrop den Zugriff zum Speichern von Inhalten in deiner Galerie verweigert. Um das zu ändern, öffne die Systemeinstellungen, gehe zu „Datenschutz & Sicherheit“ > „Fotos“ und aktiviere den Schalter für QuickDrop."
                }
              },
              "other" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "Du hast QuickDrop den Zugriff zum Speichern von Inhalten in deiner Galerie verweigert. Um das zu ändern, öffne die Einstellungen, suche nach „QuickDrop“ und setze die Option „Fotos“ auf „Nur Fotos hinzufügen“."
                }
              }
            }
          }
        },
        "el" : {
          "variations" : {
            "device" : {
              "mac" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "Αρνηθήκατε στην QuickDrop την πρόσβαση για αποθήκευση περιεχομένου στη συλλογή σας. Για να το αλλάξετε, ανοίξτε τις Ρυθμίσεις συστήματος, πηγαίνετε στο \"Απόρρητο & Ασφάλεια\" > \"Φωτογραφίες\" και ενεργοποιήστε τον διακόπτη για το QuickDrop."
                }
              },
              "other" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "Αρνηθήκατε στην QuickDrop την πρόσβαση για αποθήκευση περιεχομένου στη συλλογή σας. Για να το αλλάξετε, ανοίξτε την εφαρμογή Ρυθμίσεις, αναζητήστε \"QuickDrop\" και αλλάξτε την επιλογή \"Φωτογραφίες\" σε \"Μόνο προσθήκη φωτογραφιών\"."
                }
              }
            }
          }
        },
