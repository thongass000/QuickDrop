    "NoLocalNetworkAccessDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "variations" : {
            "device" : {
              "mac" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "لقد منعت وصول QuickDrop إلى الشبكة المحلية. لا يمكن لـ QuickDrop العمل بدون هذا الإذن. افتح إعدادات النظام، ثم انتقل إلى \"الخصوصية والأمان\" > \"الشبكة المحلية\". تأكد من تفعيل QuickDrop."
                }
              },
              "other" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "لقد منعت وصول QuickDrop إلى الشبكة المحلية. لا يمكن لـ QuickDrop العمل بدون هذا الإذن. اضغط هنا لمنح إذن الوصول للشبكة المحلية."
                }
              }
            }
          }
        },
        "ca" : {
          "variations" : {
            "device" : {
              "mac" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "Has denegat l'accés a la xarxa local per a QuickDrop. QuickDrop no pot funcionar sense aquest permís. Obre la Configuració del sistema i ves a \"Privadesa i seguretat\" > \"Xarxa local\". Assegura't que QuickDrop estigui activat."
                }
              },
              "other" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "Has denegat l'accés a la xarxa local per a QuickDrop. QuickDrop no pot funcionar sense aquest permís. Fes clic aquí per concedir l'accés a la xarxa local."
                }
              }
            }
          }
        },
        "cs" : {
          "variations" : {
            "device" : {
              "mac" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "Odepřeli jste QuickDropu přístup k místní síti. Bez tohoto oprávnění nebude QuickDrop fungovat. Otevřete Systémová nastavení a přejděte na „Soukromí a zabezpečení“ > „Místní síť“. Ujistěte se, že je QuickDrop povolen."
                }
              },
              "other" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "Odepřeli jste QuickDropu přístup k místní síti. Bez tohoto oprávnění nebude QuickDrop fungovat. Klikněte zde pro povolení přístupu k místní síti."
                }
              }
            }
          }
        },
        "da" : {
          "variations" : {
            "device" : {
              "mac" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "Du har nægtet QuickDrop adgang til det lokale netværk. QuickDrop kan ikke fungere uden denne tilladelse. Åbn Systemindstillinger og gå til \"Privatliv & Sikkerhed\" > \"Lokalt netværk\". Sørg for, at QuickDrop er aktiveret."
                }
              },
              "other" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "Du har nægtet QuickDrop adgang til det lokale netværk. QuickDrop kan ikke fungere uden denne tilladelse. Klik her for at give adgang til det lokale netværk."
                }
              }
            }
          }
        },
        "de" : {
          "variations" : {
            "device" : {
              "mac" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "Du hast QuickDrop den Zugriff auf das lokale Netzwerk verweigert. Ohne diese Berechtigung funktioniert QuickDrop nicht. Öffne die Systemeinstellungen und gehe zu „Datenschutz & Sicherheit“ > „Lokales Netzwerk“. Stelle sicher, dass QuickDrop aktiviert ist."
                }
              },
              "other" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "Du hast QuickDrop den Zugriff auf das lokale Netzwerk verweigert. Ohne diese Berechtigung funktioniert QuickDrop nicht. Klicke hier, um den Zugriff zu erlauben."
                }
              }
            }
          }
        },
        "el" : {
          "variations" : {
            "device" : {
              "mac" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "Απορρίψατε την πρόσβαση στο τοπικό δίκτυο για το QuickDrop. Το QuickDrop δεν μπορεί να λειτουργήσει χωρίς αυτήν την άδεια. Ανοίξτε τις Ρυθμίσεις συστήματος και πηγαίνετε στο «Απόρρητο & Ασφάλεια» > «Τοπικό Δίκτυο». Βεβαιωθείτε ότι το QuickDrop είναι ενεργοποιημένο."
                }
              },
              "other" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "Απορρίψατε την πρόσβαση στο τοπικό δίκτυο για το QuickDrop. Το QuickDrop δεν μπορεί να λειτουργήσει χωρίς αυτήν την άδεια. Κάντε κλικ εδώ για να δώσετε πρόσβαση στο τοπικό δίκτυο."
                }
              }
            }
          }
        },
        "en" : {
          "variations" : {
            "device" : {
              "mac" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "You denied local network access for QuickDrop. QuickDrop cannot work without this permission. Open System Settings, and go to \"Privacy & Security\" > \"Local Network\". Make sure that QuickDrop is enabled."
