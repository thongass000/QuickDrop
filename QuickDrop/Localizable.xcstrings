    "TransferDeclined" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "رفض الجهاز الآخر عملية النقل. الرجاء المحاولة مرة أخرى."
