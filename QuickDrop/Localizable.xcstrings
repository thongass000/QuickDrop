    "introduction_no_wifi_description" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لاستخدام QuickDrop، يرجى توصيل جهاز Mac الخاص بك بشبكة Wi-Fi. إذا كنت مسافراً، يمكنك استخدام خاصية نقطة الاتصال في هاتفك."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Per utilitzar QuickDrop, connecta el teu Mac a una xarxa Wi-Fi. Si estàs de viatge, pots utilitzar la funció de punt d'accés del teu telèfon."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pro použití QuickDrop připojte svůj Mac k Wi-Fi síti. Pokud cestujete, můžete využít hotspot svého telefonu."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "For at bruge QuickDrop skal du forbinde din Mac til et Wi-Fi-netværk. Hvis du er ude at rejse, kan du bruge hotspot-funktionen på din telefon."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Um QuickDrop zu nutzen, verbinde deinen Mac bitte mit einem WLAN. Wenn du unterwegs bist, kannst du den Hotspot deines Handys verwenden."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Για να χρησιμοποιήσετε το QuickDrop, παρακαλώ συνδέστε το Mac σας σε δίκτυο Wi-Fi. Αν ταξιδεύετε, μπορείτε να χρησιμοποιήσετε τη λειτουργία hotspot του τηλεφώνου σας."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "To use QuickDrop, please connect your Mac to a Wi-Fi network. If you are traveling, you may use the hotspot feature of your phone."
          }
        },
        "en-AU" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "To use QuickDrop, please connect your Mac to a Wi-Fi network. If you are travelling, you may use the hotspot feature of your phone."
          }
        },
        "en-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "To use QuickDrop, please connect your Mac to a Wi-Fi network. If you are travelling, you may use the hotspot feature of your phone."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "To use QuickDrop, please connect your Mac to a Wi-Fi network. If you are travelling, you may use the hotspot feature of your phone."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Para usar QuickDrop, conecta tu Mac a una red Wi-Fi. Si estás de viaje, puedes usar la función de punto de acceso de tu teléfono."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Para usar QuickDrop, conecta tu Mac a una red Wi-Fi. Si estás viajando, puedes usar la función de hotspot de tu teléfono."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Käyttääksesi QuickDropia, yhdistä Macisi Wi-Fi-verkkoon. Jos olet matkalla, voit käyttää puhelimesi hotspot-toimintoa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pour utiliser QuickDrop, veuillez connecter votre Mac à un réseau Wi-Fi. Si vous voyagez, vous pouvez utiliser la fonction hotspot de votre téléphone."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pour utiliser QuickDrop, veuillez connecter votre Mac à un réseau Wi-Fi. Si vous voyagez, vous pouvez utiliser la fonction point d'accès de votre téléphone."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "כדי להשתמש ב-QuickDrop, חבר את ה-Mac שלך לרשת Wi-Fi. אם אתה בתנועה, אפשר להשתמש בתכונת ה-hotspot של הטלפון שלך."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop का उपयोग करने के लिए कृपया अपने Mac को Wi-Fi नेटवर्क से जोड़ें। यदि आप यात्रा कर रहे हैं तो फोन का हॉटस्पॉट इस्तेमाल कर सकते हैं।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Za korištenje QuickDropa povežite svoj Mac na Wi-Fi mrežu. Ako putujete, možete koristiti hotspot sa svog mobitela."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A QuickDrop használatához csatlakoztassa Mac-jét Wi-Fi hálózathoz. Ha utazik, használhatja a telefonja hotspot funkcióját is."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Untuk menggunakan QuickDrop, silakan hubungkan Mac Anda ke jaringan Wi-Fi. Jika Anda sedang bepergian, Anda bisa menggunakan fitur hotspot di ponsel Anda."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Per usare QuickDrop, collega il Mac a una rete Wi-Fi. Se sei in viaggio, puoi usare l'hotspot del tuo telefono."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDropを使用するには、MacをWi-Fiネットワークに接続してください。旅行中の場合は、スマートフォンのホットスポット機能も利用できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop을 사용하려면 Mac을 Wi-Fi 네트워크에 연결하세요. 여행 중이라면 휴대폰의 핫스팟 기능을 사용할 수 있습니다."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Untuk menggunakan QuickDrop, sila sambungkan Mac anda ke rangkaian Wi-Fi. Jika anda sedang dalam perjalanan, anda boleh gunakan fungsi hotspot pada telefon anda."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "For å bruke QuickDrop må du koble Mac-en til et Wi-Fi-nettverk. Hvis du er på reise, kan du bruke mobilens hotspot-funksjon."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Om QuickDrop te gebruiken, verbind je Mac met een Wi-Fi-netwerk. Ben je onderweg, gebruik dan de hotspot van je telefoon."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aby korzystać z QuickDrop, połącz swojego Maca z siecią Wi-Fi. Jeśli podróżujesz, możesz użyć funkcji hotspotu w telefonie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Para usar o QuickDrop, conecte seu Mac a uma rede Wi-Fi. Se estiver viajando, utilize o recurso hotspot do seu celular."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Para usar o QuickDrop, ligue o seu Mac a uma rede Wi-Fi. Se estiver a viajar, pode utilizar o hotspot do seu telemóvel."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pentru a folosi QuickDrop, conectează Mac-ul la o rețea Wi-Fi. Dacă ești în deplasare, poți folosi hotspot-ul telefonului."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Чтобы использовать QuickDrop, подключите ваш Mac к сети Wi-Fi. В поездке можно использовать точку доступа телефона."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "För att använda QuickDrop, anslut din Mac till ett Wi-Fi-nätverk. Om du reser kan du använda mobilens hotspotfunktion."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ในการใช้ QuickDrop กรุณาเชื่อมต่อ Mac ของคุณกับเครือข่าย Wi-Fi หากคุณกำลังเดินทาง สามารถใช้ฮอตสปอตจากโทรศัพท์ได้"
          }
        },
        "tr" : {
          "stringUnit" : {
