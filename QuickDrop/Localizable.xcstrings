    "DownloadCableConnectionAppDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "إذا كنت تريد نقل الملفات واستعراض تخزين جهاز Android الخاص بك عبر USB، يمكنك الآن القيام بذلك باستخدام تطبيق iDroid الجديد.\n\niDroid يدعم تنزيل وتحميل الملفات والمجلدات الكاملة باستخدام السحب والإفلات."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si vols transferir arxius i explorar l'emmagatzematge del teu dispositiu Android a través d'USB, ara pots fer-ho amb la nova app iDroid.\n\niDroid admet la descàrrega i càrrega d'arxius i carpetes senceres mitjançant Drag & Drop."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chcete-li přenášet soubory a procházet úložiště svého zařízení Android přes USB, nyní můžete použít novou aplikaci iDroid.\n\niDroid podporuje stahování a nahrávání souborů a celých složek pomocí Drag & Drop."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hvis du vil overføre filer og gennemse din Android-enheds lager via USB, kan dette nu gøres med den nye iDroid app.\n\niDroid understøtter download og upload af filer og hele mapper ved hjælp af Drag & Drop."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn du Dateien übertragen und den Speicher deines Android-Geräts per USB durchsuchen willst, kannst du das jetzt mit der neuen iDroid-App tun.\n\niDroid unterstützt das Herunterladen und Hochladen von Dateien und ganzen Ordnern per Drag & Drop."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Αν θέλετε να μεταφέρετε αρχεία και να περιηγηθείτε στον αποθηκευτικό χώρο της συσκευής Android μέσω USB, μπορείτε τώρα να το κάνετε με τη νέα εφαρμογή iDroid.\n\nΤο iDroid υποστηρίζει κατέβασμα και αποστολή αρχείων και ολόκληρων φακέλων μέσω Drag & Drop."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If you want to transfer files and browse the storage of your Android device via USB, you can now do so with the new iDroid app.\n\niDroid supports downloading and uploading files and whole folders using Drag & Drop."
          }
        },
        "en-AU" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Transfer files via USB with iDroid for Android. Drag & Drop supported."
          }
        },
        "en-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "To transfer files via USB or browse Android storage, use the iDroid app. Drag & Drop for folders and files is supported."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Transfer files via USB and browse Android's storage using the new iDroid app. Drag & Drop supported."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si deseas transferir archivos y explorar el almacenamiento de tu dispositivo Android mediante USB, ahora puedes hacerlo con la nueva aplicación iDroid.\n\niDroid admite la descarga y carga de archivos y carpetas completas mediante arrastrar y soltar."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si deseas transferir archivos y explorar el almacenamiento de tu dispositivo Android a través de USB, ahora puedes hacerlo con la nueva aplicación iDroid.\n\niDroid permite descargar y subir archivos y carpetas completas usando arrastrar y soltar."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jos haluat siirtää tiedostoja ja selata Android-laitteesi tallennusta USB:n kautta, tee se nyt uudella iDroid-sovelluksella.\n\niDroid tukee tiedostojen ja kokonaisia kansioiden lataamista ja lähettämistä vedä ja pudota -menetelmällä."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si vous souhaitez transférer des fichiers et explorer le stockage de votre appareil Android via USB, vous pouvez maintenant le faire avec la nouvelle application iDroid.\n\niDroid prend en charge le téléchargement et l'envoi de fichiers et dossiers entiers avec le glisser-déposer."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si vous souhaitez transférer des fichiers et parcourir le stockage de votre appareil Android via USB, vous pouvez maintenant le faire avec la nouvelle application iDroid.\n\niDroid permet de télécharger et de charger des fichiers ou des dossiers entiers en utilisant Glisser-Déposer."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "אם ברצונך להעביר קבצים ולעיין באחסון של מכשיר ה-Android שלך באמצעות USB, כעת תוכל לעשות זאת עם אפליקציית iDroid החדשה.\n\niDroid תומכת בהורדה והעלאה של קבצים ותיקיות שלמות באמצעות גרירה והשלכה."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यदि आप USB के माध्यम से अपने Android डिवाइस की स्टोरेज को एक्सेस करना चाहते हैं, तो आप अब नए iDroid ऐप का उपयोग करके ऐसा कर सकते हैं।\n\niDroid Drag & Drop के माध्यम से फ़ाइलें और पूरे फ़ोल्डर डाउनलोड और अपलोड करने का समर्थन करता है।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ako želite prenositi datoteke i pregledavati pohranu svog Android uređaja putem USB-a, sada to možete učiniti s novom iDroid aplikacijom.\n\niDroid podržava preuzimanje i prijenos datoteka i cijelih mapa pomoću Drag & Drop funkcionalnosti."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ha fájlokat szeretnél áthelyezni és böngészni Android-eszközöd tárhelyét USB-n keresztül, most megteheted az új iDroid alkalmazással.\n\niDroid támogatja a fájlok és teljes mappák letöltését és feltöltését húzással és ejtéssel."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jika Anda ingin mentransfer file dan menjelajahi penyimpanan perangkat Android Anda melalui USB, Anda sekarang dapat melakukannya dengan aplikasi iDroid yang baru.\n\niDroid mendukung pengunduhan dan pengunggahan file serta seluruh folder menggunakan Seret & Lepas."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se desideri trasferire file e navigare nella memoria del tuo dispositivo Android tramite USB, ora puoi farlo con la nuova app iDroid.\n\niDroid supporta il download e il caricamento di file e cartelle intere tramite Drag & Drop."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "USB経由でAndroidデバイスのファイルを転送し、ストレージを閲覧したい場合は、新しいiDroidアプリを使って実現できます。\n\niDroidはドラッグ＆ドロップによるファイルやフォルダのダウンロードとアップロードをサポートしています。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "USB를 통해 Android 기기의 파일을 전송하고 저장소를 탐색하려면, 이제 새롭게 출시된 iDroid 앱을 사용해보세요.\n\niDroid는 드래그 앤 드롭으로 전체 폴더 및 파일의 다운로드와 업로드를 지원합니다."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jika anda ingin memindahkan fail dan menyemak storan peranti Android anda melalui USB, kini anda boleh melakukannya dengan aplikasi iDroid yang baru.\n\niDroid menyokong memuat turun dan memuat naik fail serta folder penuh menggunakan Drag & Drop."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hvis du vil overføre filer og bla gjennom lagringen på din Android-enhet via USB, kan du nå gjøre det med den nye iDroid-appen.\n\niDroid støtter nedlasting og opplastning av filer og hele mapper ved hjelp av Drag & Drop."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Als je bestanden wilt overzetten en de opslag van je Android-apparaat via USB wilt verkennen, kan dat nu met de nieuwe iDroid-app.\n\niDroid ondersteunt het downloaden en uploaden van bestanden en volledige mappen via slepen en neerzetten."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chcesz przesyłać pliki i przeglądać dane Androida poprzez USB? Teraz możesz to zrobić dzięki nowej aplikacji iDroid.\n\niDroid obsługuje pobieranie i przesyłanie plików oraz całych folderów przy użyciu funkcji Przeciągnij i Upuść."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se você deseja transferir arquivos e navegar no armazenamento do seu dispositivo Android via USB, agora pode fazer isso com o novo app iDroid.\n\niDroid suporta download e upload de arquivos e pastas inteiras usando Arrastar e Soltar."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se pretendes transferir ficheiros e explorar o armazenamento do teu dispositivo Android via USB, agora podes fazê-lo com a nova aplicação iDroid.\n\niDroid suporta transferência e envio de ficheiros e pastas inteiras através de arrastar e largar."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dacă dorești să transferi fișiere și să explorezi stocarea dispozitivului tău Android prin USB, acum poți face acest lucru cu noua aplicație iDroid.\n\niDroid permite descărcarea și încărcarea fișierelor și folderelor întregi prin tragere și plasare."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Если вы хотите передавать файлы и просматривать хранилище вашего Android-устройства через USB, теперь вы можете сделать это с помощью нового приложения iDroid.\n\niDroid поддерживает загрузку и передачу файлов и целых папок с помощью перетаскивания."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Om du vill överföra filer och bläddra Android-enhetens lagring via USB, kan du nu göra detta med den nya iDroid-appen.\n\niDroid stöder nedladdning och uppladdning av filer och hela mappar på Drag & Drop-sätt."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "หากคุณต้องการถ่ายโอนไฟล์และเรียกดูที่เก็บข้อมูลของอุปกรณ์ Android ผ่าน USB ตอนนี้คุณสามารถทำได้ด้วยแอป iDroid ใหม่\n\niDroid รองรับการดาวน์โหลดและอัปโหลดไฟล์และโฟลเดอร์ทั้งหมดด้วยการลากและวาง"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dosya transfer etmek ve Android cihazınızın depolamasını USB üzerinden taramak istiyorsanız, artık yeni iDroid uygulamasıyla bunu yapabilirsiniz.\n\niDroid, dosyaları ve bütün klasörleri Sürükle&Bırak ile indirip yüklemeyi destekler."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Якщо ви хочете передавати файли та переглядати сховище вашого Android-пристрою через USB, тепер це можливо з новим додатком iDroid.\n\niDroid підтримує завантаження та надсилання файлів і цілих папок через перетягування."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nếu bạn muốn truyền tệp và duyệt bộ nhớ của thiết bị Android qua USB, giờ đây bạn có thể thực hiện điều đó với ứng dụng iDroid mới.\n\niDroid hỗ trợ tải xuống và tải lên tệp và toàn bộ thư mục bằng cách Kéo & Thả."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果您想通过 USB 传输文件并浏览 Android 设备的存储空间，现在可以使用全新的 iDroid 应用程序。\n\niDroid 支持通过拖放下载和上传文件及整个文件夹。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果您想通過 USB 傳輸文件並瀏覽 Android 設備的存儲空間，現在可以使用新的 iDroid 應用程式。\n\niDroid 支援下載和上傳文件以及整個文件夾，並支持拖放操作。"
          }
        }
      }
    },
