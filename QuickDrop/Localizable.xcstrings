        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Відкрийте QuickDrop+, щоб без обмежень обмінюватися файлами. Усі поточні й майбутні функції включено, а також додатки для macOS і Android."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mở khóa QuickDrop+ để tiếp tục chia sẻ tệp không giới hạn. Bao gồm tất cả tính năng hiện tại và sắp tới, cùng với ứng dụng macOS và Android."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
