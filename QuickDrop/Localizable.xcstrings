            }
          }
        },
        "hu" : {
          "variations" : {
            "device" : {
              "mac" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "Ön megtagadta a helyi hálózathoz való hozzáférést a QuickDrop számára. A QuickDrop nem működik ezen engedély nélkül. Nyissa meg a Rendszerbeállításokat, majd menjen a „Adatvédelem és biztonság” > „Helyi hálózat” menüponthoz. Győződjön meg arról, hogy a QuickDrop engedélyezve van."
