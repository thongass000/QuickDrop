          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Voit lisätä luotettuja laitteita vastaanottaaksesi tiedostoja ilman manuaalista hyväksyntää."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous pouvez ajouter des appareils de confiance pour recevoir des fichiers sans avoir à les accepter manuellement."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous pouvez ajouter des appareils de confiance pour recevoir des fichiers sans avoir à les accepter manuellement."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "אפשר להוסיף מכשירים מהימנים כדי לקבל קבצים ללא צורך באישור ידני."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आप विश्वसनीय डिवाइस जोड़ सकते हैं ताकि फाइलें बिना मैन्युअल स्वीकृति के प्राप्त हों।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Možete dodati pouzdane uređaje za primanje datoteka bez ručnog prihvaćanja."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hozzáadhatsz megbízható eszközöket, hogy kézi elfogadás nélkül fogadhass fájlokat."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anda dapat menambahkan perangkat tepercaya untuk menerima file tanpa harus menerimanya secara manual."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Puoi aggiungere dispositivi attendibili per ricevere file senza doverli accettare manualmente."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "信頼できるデバイスを追加すると、手動で承認せずにファイルを受信できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "신뢰할 수 있는 기기를 추가하면 수동 승인 없이 파일을 받을 수 있습니다."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anda boleh tambah peranti dipercayai untuk terima fail tanpa perlu menerimanya secara manual."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du kan legge til betrodde enheter for å motta filer uten å måtte godkjenne dem manuelt."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Je kunt vertrouwde apparaten toevoegen om bestanden te ontvangen zonder deze handmatig te hoeven accepteren."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Możesz dodać zaufane urządzenia, by otrzymywać pliki bez konieczności ręcznego akceptowania."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você pode adicionar dispositivos confiáveis para receber arquivos sem precisar aceitá-los manualmente."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pode adicionar dispositivos de confiança para receber ficheiros sem ter de os aceitar manualmente."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Poți adăuga dispozitive de încredere pentru a primi fișiere fără acceptare manuală."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вы можете добавить доверенные устройства, чтобы получать файлы без ручного подтверждения."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du kan lägga till betrodda enheter för att ta emot filer utan att behöva godkänna dem manuellt."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "คุณสามารถเพิ่มอุปกรณ์ที่เชื่อถือได้เพื่อรับไฟล์โดยไม่ต้องกดยอมรับด้วยตนเอง"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Güvenilen cihazlar ekleyerek dosyaları manuel olarak onaylamadan alabilirsiniz."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ви можете додати довірені пристрої, щоб отримувати файли без ручного підтвердження."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bạn có thể thêm thiết bị tin cậy để nhận tệp mà không cần phải chấp nhận thủ công."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您可以添加受信任的设备，这样接收文件时无需手动确认。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您可以新增信任的裝置來自動接收檔案，無需手動接受。"
          }
        }
      }
    },
