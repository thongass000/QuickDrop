          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Došlo je do nepoznate pogreške prilikom spremanja fotografija ili videozapisa u vašu galeriju. Molimo razmislite o prijavljivanju ove pogreške."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ismeretlen hiba történt a fotók vagy videók galériába mentésekor. Kérjük, fontold meg a hiba jelentését."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Terjadi kesalahan tidak dikenal saat mencoba menyimpan foto atau video ke galeri Anda. Silakan pertimbangkan untuk melaporkan kesalahan ini."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si è verificato un errore sconosciuto durante il salvataggio di foto o video nella tua galleria. Ti invitiamo a segnalare questo errore."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "写真や動画をギャラリーに保存中に不明なエラーが発生しました。このエラーの報告をご検討ください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "사진 또는 비디오를 갤러리에 저장하는 중 알 수 없는 오류가 발생했습니다. 이 오류를 보고해 주세요."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ralat tidak diketahui berlaku semasa cuba menyimpan foto atau video ke galeri anda. Sila pertimbangkan untuk melaporkan ralat ini."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En ukjent feil oppstod ved lagring av bilder eller videoer i galleriet ditt. Vurder å rapportere denne feilen."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Er is een onbekende fout opgetreden bij het opslaan van foto's of video's in je galerij. Overweeg dit probleem te melden."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wystąpił nieznany błąd podczas zapisywania zdjęć lub filmów w galerii. Prosimy o rozważenie zgłoszenia tego błędu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ocorreu um erro desconhecido ao tentar salvar fotos ou vídeos na sua galeria. Considere relatar esse erro."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ocorreu um erro desconhecido ao tentar guardar fotos ou vídeos na tua galeria. Por favor, considera reportar este erro."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A apărut o eroare necunoscută la încercarea de a salva fotografiile sau videoclipurile în galerie. Te rugăm să raportezi această eroare."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Произошла неизвестная ошибка при попытке сохранить фото или видео в галерею. Пожалуйста, сообщите об этой ошибке."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ett okänt fel uppstod när bilder eller videor skulle sparas i ditt galleri. Vänligen överväg att rapportera detta fel."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "เกิดข้อผิดพลาดที่ไม่ทราบสาเหตุขณะพยายามบันทึกรูปภาพหรือวิดีโอลงในแกลเลอรี่ของคุณ กรุณารายงานข้อผิดพลาดนี้"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fotoğraf veya videolar galerinize kaydedilmeye çalışılırken bilinmeyen bir hata oluştu. Lütfen bu hatayı bildirmeniz gerektiğini düşünün."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сталася невідома помилка під час спроби зберегти фото або відео до вашої галереї. Будь ласка, розгляньте можливість повідомити про цю помилку."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Đã xảy ra lỗi không xác định khi cố lưu ảnh hoặc video vào thư viện của bạn. Vui lòng cân nhắc báo cáo lỗi này."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在尝试将照片或视频保存到图库时发生未知错误。请考虑报告此错误。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "嘗試將照片或影片儲存至相簿時發生未知錯誤。請考慮回報此錯誤。"
          }
        }
      }
