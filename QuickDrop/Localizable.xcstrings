    "TypeNotSupportedDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "نوع الملف المحدد غير مدعوم. إذا كنت ترغب في مشاركته على أي حال، انقر بزر الفأرة الأيمن على الملف، واختر \"ضغط\" ثم أرسل الملف المضغوط."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El tipus d'arxiu seleccionat no és compatible. Si igualment vols compartir-lo, fes clic dret a l'arxiu, selecciona \"Comprimir\" i després envia l'arxiu comprimit."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vybraný typ souboru není podporován. Pokud ho chcete přesto sdílet, klikněte pravým tlačítkem na soubor, zvolte \"Komprimovat\" a poté pošlete komprimovaný soubor."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Den valgte filtype understøttes ikke. Hvis du vil dele den alligevel, højreklik på filen, vælg \"Komprimer\" og send derefter den komprimerede fil."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der ausgewählte Dateityp wird nicht unterstützt. Wenn du ihn trotzdem teilen möchtest, klicke mit der rechten Maustaste auf die Datei, wähle „Komprimieren“ aus und sende dann die komprimierte Datei."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ο επιλεγμένος τύπος αρχείου δεν υποστηρίζεται. Αν θέλετε να το κοινοποιήσετε παρόλα αυτά, κάντε δεξί κλικ στο αρχείο, επιλέξτε \"Συμπίεση\" και μετά στείλτε το συμπιεσμένο αρχείο."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The selected file type is not supported. If you want to share it anyway, right-click the file, select \"Compress\" and then send the compressed file."
          }
        },
        "en-AU" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unsupported type. To share, right-click, compress, then send the zipped file."
          }
        },
        "en-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This file type isn’t supported. If needed, right-click the file, choose \"Compress,\" then transfer the compressed file."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This file type isn’t supported. To share it, compress the file (right-click > Compress), then try sending again."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El tipo de archivo seleccionado no es compatible. Si aún deseas compartirlo, haz clic derecho en el archivo, selecciona \"Comprimir\" y luego envía el archivo comprimido."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El tipo de archivo seleccionado no es compatible. Si deseas compartirlo de todos modos, haz clic derecho en el archivo, selecciona \"Comprimir\" y luego envía el archivo comprimido."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Valittua tiedostotyyppiä ei tueta. Jos haluat silti jakaa sen, napsauta tiedostoa hiiren oikealla painikkeella, valitse 'Pakkaa' ja lähetä pakattu tiedosto."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le type de fichier sélectionné n'est pas pris en charge. Si vous souhaitez tout de même le partager, faites un clic droit sur le fichier, sélectionnez \"Compresser\" puis envoyez le fichier compressé."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le type de fichier sélectionné n'est pas pris en charge. Si vous voulez quand même le partager, faites un clic droit sur le fichier, sélectionnez « Compresser », puis envoyez le fichier compressé."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "סוג הקובץ שנבחר אינו נתמך. אם ברצונך לשתף אותו בכל זאת, לחץ על הקובץ עם לחצן ימני, בחר \"דחוס\" ואז שלח את הקובץ המכווץ."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "चयनित फ़ाइल प्रकार समर्थित नहीं है। यदि आप इसे साझा करना चाहते हैं, तो फ़ाइल पर राइट-क्लिक करें, \"Compress\" चुनें और फिर कंप्रेस्ड फ़ाइल भेजें।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Odabrani tip datoteke nije podržan. Ako ga svejedno želite podijeliti, desnim klikom odaberite datoteku, odaberite \"Sažmi\" i zatim pošaljite sažetu datoteku."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A kiválasztott fájltípus nem támogatott. Ha mégis meg szeretnéd osztani, kattints jobb gombbal a fájlra, válaszd a \"Tömörítés\" lehetőséget, majd küldd el a tömörített fájlt."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jenis file yang dipilih tidak didukung. Jika Anda tetap ingin membagikannya, klik kanan file tersebut, pilih \"Kompres\" dan kemudian kirim file terkompresi."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il tipo di file selezionato non è supportato. Se desideri comunque condividerlo, fai clic con il tasto destro sul file, seleziona \"Comprimi\" e poi invia il file compresso."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "選択したファイルの形式はサポートされていません。それでも共有したい場合は、ファイルを右クリックして「圧縮」を選択し、圧縮ファイルを送信してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "선택한 파일 형식은 지원되지 않습니다. 그래도 공유하려면 파일을 오른쪽 클릭하여 '압축'을 선택한 후 압축된 파일을 보내세요."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jenis fail yang dipilih tidak disokong. Jika anda mahu tetap berkongsi, klik kanan pada fail, pilih \"Compress\" dan kemudian hantar fail terkompresi."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Den valgte filtypen støttes ikke. Hvis du vil dele den uansett, høyreklikk på filen, velg \"Komprimer\" og send deretter den komprimerte filen."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Het geselecteerde bestandstype wordt niet ondersteund. Als je het toch wilt delen, klik met de rechtermuisknop op het bestand, selecteer \"Comprimeren\" en stuur vervolgens het gecomprimeerde bestand."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wybrany typ pliku nie jest obsługiwany. Jeśli chcesz go udostępnić, kliknij plik prawym przyciskiem myszy, wybierz ‚Skompresuj‘, a następnie wyślij skompresowany plik."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O tipo de arquivo selecionado não é suportado. Se quiser compartilhá-lo mesmo assim, clique com o botão direito no arquivo, selecione \"Comprimir\" e envie o arquivo compactado."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O tipo de ficheiro selecionado não é suportado. Se quiser partilhá-lo mesmo assim, clique com o botão direito no ficheiro, selecione \"Comprimir\" e depois envie o ficheiro comprimido."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tipul de fișier selectat nu este acceptat. Dacă dorești să îl trimiți oricum, fă clic dreapta pe fișier, selectează \"Comprimă\" și apoi trimite fișierul comprimat."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Выбранный тип файла не поддерживается. Если вы все равно хотите его отправить, щелкните файл правой кнопкой мыши, выберите «Сжать», а затем отправьте сжатый файл."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Den valda filtypen stöds inte. Om du ändå vill dela den, högerklicka på filen, välj \"Komprimera\" och skicka sedan den komprimerade filen."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ประเภทไฟล์ที่เลือกไม่รองรับ หากต้องการแชร์อยู่ดี ให้คลิกขวาที่ไฟล์ เลือก \"บีบอัด\" แล้วส่งไฟล์ที่บีบอัดแล้ว"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seçilen dosya türü desteklenmiyor. Yine de paylaşmak istiyorsanız, dosyaya sağ tıklayıp \"Sıkıştır\"ı seçin ve ardından sıkıştırılmış dosyayı gönderin."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вибраний тип файлу не підтримується. Якщо ви все одно хочете його надіслати, клацніть файл правою кнопкою миші, виберіть \"Стиснути\", а потім надішліть стиснутий файл."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Loại tệp được chọn không được hỗ trợ. Nếu bạn vẫn muốn chia sẻ, nhấp chuột phải vào tệp, chọn \"Nén\" và sau đó gửi tệp đã nén."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "所选文件类型不受支持。如果仍要分享，请右键点击文件，选择“压缩”，然后发送压缩后的文件。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "所選檔案類型不受支援。如果您仍希望共享，請右鍵點擊該檔案，選擇「壓縮」，然後傳送壓縮檔案。"
          }
        }
      }
    },
