    "SaveToPhotosErrorSaveFailed" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "حدث خطأ غير معروف أثناء محاولة حفظ الصور أو الفيديوهات في معرضك. يرجى التفكير في الإبلاغ عن هذا الخطأ."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "S'ha produït un error desconegut en intentar desar fotos o vídeos a la galeria. Si us plau, considera informar d'aquest error."
