    "Error.FixInstructions" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "إذا تكرر هذا الأمر، يرجى إعادة تشغيل هاتفك أو محاولة تنزيل تطبيق QuickDrop للأندرويد من متجر Google Play."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si això passa repetidament, reinicia el telèfon o prova de descarregar l'app QuickDrop per a Android des de Google Play."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pokud se to opakuje, restartujte prosím svůj telefon nebo zkuste stáhnout aplikaci QuickDrop pro Android z Google Play."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hvis dette sker gentagne gange, så genstart venligst din telefon eller prøv at downloade QuickDrop Android-appen fra Google Play."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn dies wiederholt passiert, starte bitte dein Handy neu oder lade die QuickDrop Android-App aus dem Google Play Store herunter."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Αν αυτό συμβαίνει επανειλημμένα, επανεκκινήστε το τηλέφωνό σας ή δοκιμάστε να κατεβάσετε την εφαρμογή QuickDrop για Android από το Google Play."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If this happens repeatedly, please restart your phone or try downloading the QuickDrop Android app from Google Play."
          }
        },
        "en-AU" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If this happens repeatedly, please restart your phone or try downloading the QuickDrop Android app from Google Play Store."
          }
        },
        "en-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If this keeps happening, please restart your phone or try downloading the QuickDrop Android app from Google Play."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If this happens repeatedly, please restart your phone or try downloading the QuickDrop Android app from Google Play Store."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si esto ocurre repetidamente, reinicia tu teléfono o intenta descargar la app QuickDrop para Android desde Google Play."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
