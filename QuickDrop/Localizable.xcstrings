    "OpenFinderAfterReceivingFooter" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "إذا تم تمكين هذا الإعداد، ستفتح نافذة Finder جديدة تلقائيًا بعد النقل، مع تحديد الملفات التي تم تنزيلها للتو من هاتفك إلى جهاز Mac الخاص بك."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si aquesta configuració està activada, una nova finestra de Finder s'obrirà automàticament després de la transferència, destacant els arxius acabats de descarregar del teu telèfon al Mac."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pokud je toto nastavení povoleno, automaticky se otevře nové okno Finderu po dokončení přenosu, zvýrazňující soubory právě stažené z telefonu do vašeho Macu."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hvis denne indstilling er aktiveret, åbner et nyt Finder-vindue automatisk efter overførslen og fremhæver filer, der lige er hentet fra din telefon til din Mac."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn diese Einstellung aktiviert ist, wird nach der Übertragung automatisch ein neues Finder-Fenster geöffnet, das die gerade von deinem Telefon auf deinen Mac heruntergeladenen Dateien hervorhebt."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Εάν ενεργοποιηθεί αυτή η ρύθμιση, θα ανοίγει αυτόματα ένα νέο παράθυρο Finder μετά τη μεταφορά, εμφανίζοντας τα αρχεία που μόλις κατεβάσατε από το τηλέφωνο στο Mac σας."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If this setting is enabled, a new Finder window will automatically open after the transfer, highlighting the files just downloaded from your phone to your Mac."
          }
        },
        "en-AU" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When enabled, Finder shows new transfers post-downloading."
          }
        },
        "en-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "With this setting, Finder will open a new window after a transfer, showcasing files recently downloaded from your phone to your Mac."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If enabled, a new Finder window opens post-transfer, showing downloaded files on your Mac."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si esta configuración está habilitada, se abrirá automáticamente una nueva ventana del Finder después de la transferencia, resaltando los archivos recién descargados de tu teléfono a tu Mac."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si esta configuración está habilitada, se abrirá automáticamente una nueva ventana de Finder después de la transferencia para resaltar los archivos recién descargados de tu teléfono a tu Mac."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jos tämä asetus on käytössä, uusi Finder-ikkuna avautuu automaattisesti siirron päätyttyä, korostaen juuri ladatut tiedostot puhelimestasi Maceesi."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si ce paramètre est activé, une nouvelle fenêtre du Finder s'ouvrira automatiquement après le transfert, mettant en évidence les fichiers juste téléchargés de votre téléphone vers votre Mac."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si ce paramètre est activé, une nouvelle fenêtre Finder s'ouvrira automatiquement après le transfert, mettant en évidence les fichiers fraîchement téléchargés de votre téléphone à votre Mac."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "אם הגדרה זו מופעלת, חלון Finder חדש ייפתח אוטומטית לאחר ההעברה ויציג את הקבצים שהורדו זה עתה מהטלפון שלך ל-Mac."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यदि यह सेटिंग सक्षम की जाती है, तो ट्रांसफर के बाद, आपके Mac पर फ़ोन से डाउनलोड की गई फ़ाइलों को हाइलाइट करते हुए एक नया फाइंडर विंडो स्वतः खुल जाएगा।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ako je ova postavka omogućena, novi prozor Finder automatski će se otvoriti nakon prijenosa, ističući datoteke upravo preuzete s vašeg telefona na vaš Mac."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ha ez a beállítás engedélyezve van, a fájlok telefonjáról a Mac-re történő letöltése után automatikusan megnyílik egy új Finder ablak, amely kiemeli az imént letöltött fájlokat."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jika pengaturan ini diaktifkan, jendela Finder baru akan terbuka secara otomatis setelah transfer selesai, menyoroti file yang baru saja diunduh dari ponsel Anda ke Mac Anda."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se questa impostazione è attivata, una nuova finestra del Finder si aprirà automaticamente dopo il trasferimento, evidenziando i file appena scaricati dal tuo telefono al tuo Mac."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "この設定を有効にすると、転送後に新しいFinderウィンドウが自動的に開き、電話からMacにダウンロードされたファイルが強調表示されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 설정이 활성화되면 전송 후 Finder 새 창이 자동으로 열리고, 휴대폰에서 Mac으로 방금 다운로드된 파일이 강조 표시됩니다."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jika tetapan ini diaktifkan, tetingkap Finder baru akan dibuka secara automatik selepas pemindahan, menyoroti fail yang baru dimuat turun dari telefon anda ke Mac anda."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hvis denne innstillingen er aktivert, åpnes et Finder-vindu automatisk etter overføringen, og fremhever filene som ble lastet ned fra telefonen din til Mac-en din."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Als deze instelling is ingeschakeld, wordt er automatisch een nieuw Finder-venster geopend na de overdracht, waarin de zojuist van je telefoon naar je Mac gedownloade bestanden worden gemarkeerd."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jeśli to ustawienie jest włączone, nowe okno Findera automatycznie otwiera się po transferze, podświetlając właśnie pobrane pliki z telefonu na Maca."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se esta configuração estiver ativada, uma nova janela do Finder será aberta automaticamente após a transferência, destacando os arquivos recém-baixados do seu telefone para o seu Mac."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se esta definição estiver ativada, uma nova janela do Finder abrir-se-á automaticamente após a transferência, destacando os ficheiros acabados de descarregar do seu telemóvel para o seu Mac."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dacă această setare este activată, o fereastră nouă Finder se va deschide automat după transfer, evidențiind fișierele tocmai descărcate de pe telefonul tău pe Mac-ul tău."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Если эта настройка включена, новое окно Finder автоматически откроется после передачи, выделяя файлы, только что загруженные с вашего телефона на ваш Mac."
