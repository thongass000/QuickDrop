    "plusview_description" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "افتح QuickDrop+ لمواصلة تبادل الملفات بلا حدود. QuickDrop+ هو عملية شراء لمرة واحدة فقط – لا تحتاج لاشتراك. جميع الميزات الحالية والمستقبلية متضمنة، بما في ذلك تطبيقات iOS وAndroid."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desbloqueja QuickDrop+ per continuar intercanviant fitxers sense límits. QuickDrop+ és una compra única – sense subscripció. Inclou totes les funcions actuals i futures, també les aplicacions per a iOS i Android."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Odemkněte QuickDrop+, abyste mohli nadále neomezeně sdílet soubory. QuickDrop+ je jednorázový nákup – žádné předplatné. Získáte všechny aktuální i budoucí funkce, včetně aplikací pro iOS a Android."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lås op for QuickDrop+ for at fortsætte filudveksling uden begrænsninger. QuickDrop+ er et engangskøb – intet abonnement kræves. Alle nuværende og fremtidige funktioner er inkluderet, inklusive iOS- og Android-apps."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schalte QuickDrop+ frei, um Dateien weiterhin unbegrenzt auszutauschen. QuickDrop+ ist ein Einmalkauf – ein Abo ist nicht nötig. Alle aktuellen und zukünftigen Funktionen sind enthalten, auch die iOS- und Android-Apps."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ξεκλειδώστε το QuickDrop+ για να συνεχίσετε να ανταλλάσσετε αρχεία χωρίς περιορισμούς. Το QuickDrop+ είναι μια εφάπαξ αγορά – δεν απαιτείται συνδρομή. Όλα τα τρέχοντα και μελλοντικά χαρακτηριστικά περιλαμβάνονται, καθώς και οι εφαρμογές iOS και Android."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unlock QuickDrop+ to continue exchanging files without limits. QuickDrop+ is a one-time purchase – no subscription required. All current and future features are included, plus the iOS and Android apps."
          }
        },
        "en-AU" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unlock QuickDrop+ to continue exchanging files without limits. QuickDrop+ is a one-time purchase – no subscription required. All current and future features are included, plus the iOS and Android apps."
          }
        },
        "en-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unlock QuickDrop+ to continue exchanging files without limits. QuickDrop+ is a one-time purchase – no subscription required. All current and future features are included, plus the iOS and Android apps."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unlock QuickDrop+ to continue exchanging files without limits. QuickDrop+ is a one-time purchase – no subscription required. All current and future features are included, plus the iOS and Android apps."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desbloquea QuickDrop+ para seguir intercambiando archivos sin límites. QuickDrop+ es una compra única, sin suscripción. Incluye todas las funciones actuales y futuras, incluidas las apps para iOS y Android."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desbloquea QuickDrop+ para seguir intercambiando archivos sin límites. QuickDrop+ es una compra única, no requiere suscripción. Incluye todas las funciones actuales y futuras, además de las apps para iOS y Android."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Avaa QuickDrop+ jatkaaksesi tiedostojen vaihtoa ilman rajoituksia. QuickDrop+ on kertaluonteinen osto – ei tilausta tarvita. Kaikki nykyiset ja tulevat ominaisuudet sisältyvät, mukaan lukien iOS- ja Android-sovellukset."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Débloquez QuickDrop+ pour continuer à échanger des fichiers sans limites. QuickDrop+ est un achat unique – aucun abonnement requis. Toutes les fonctionnalités actuelles et futures sont incluses, y compris les applications iOS et Android."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Déverrouillez QuickDrop+ pour continuer à échanger des fichiers sans limites. QuickDrop+ est un achat unique – aucun abonnement requis. Toutes les fonctionnalités actuelles et futures sont incluses, y compris les applis iOS et Android."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "פתח את QuickDrop+ כדי להמשיך להחליף קבצים ללא הגבלה. QuickDrop+ היא רכישה חד-פעמית – אין צורך במנוי. כל התכונות הנוכחיות והעתידיות כלולות, כולל אפליקציות ל-iOS ולאנדרואיד."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "फाइलों का आदान-प्रदान बिना किसी सीमा के जारी रखने के लिए QuickDrop+ अनलॉक करें। QuickDrop+ एक बार की खरीदारी है – कोई सदस्यता नहीं चाहिए। सभी वर्तमान और भविष्य की सुविधाएँ शामिल हैं, जैसे iOS और Android ऐप्स।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Otključajte QuickDrop+ za neograničenu razmjenu datoteka. QuickDrop+ je jednokratna kupnja – nema pretplate. Sve sadašnje i buduće značajke su uključene, uključujući iOS i Android aplikacije."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oldd fel a QuickDrop+ szolgáltatást, hogy korlátlanul cserélhess fájlokat. A QuickDrop+ egyszeri vásárlás – nincs előfizetés. Minden jelenlegi és jövőbeli funkciót tartalmaz, beleértve az iOS és Android alkalmazásokat is."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Buka QuickDrop+ untuk terus bertukar file tanpa batas. QuickDrop+ adalah pembelian sekali bayar – tidak perlu berlangganan. Semua fitur saat ini dan mendatang termasuk, juga aplikasi iOS dan Android."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sblocca QuickDrop+ per continuare a scambiare file senza limiti. QuickDrop+ è un acquisto unico – nessun abbonamento richiesto. Sono incluse tutte le funzionalità attuali e future, comprese le app per iOS e Android."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop+をアンロックして、無制限でファイル交換を続けましょう。QuickDrop+は買い切り型で、サブスクリプションは不要です。iOSやAndroidアプリを含む、現在および今後のすべての機能が含まれます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop+를 잠금 해제하여 파일을 무제한으로 주고받으세요. QuickDrop+는 일회성 구매이며, 구독이 필요하지 않습니다. 현재 및 향후 모든 기능이 포함되어 있으며, iOS 및 Android 앱도 포함됩니다."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Buka kunci QuickDrop+ untuk terus berkongsi fail tanpa had. QuickDrop+ adalah pembelian sekali sahaja – tiada langganan diperlukan. Semua ciri semasa dan akan datang disertakan, termasuk aplikasi iOS dan Android."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lås opp QuickDrop+ for å fortsette å utveksle filer uten begrensninger. QuickDrop+ er et engangskjøp – ingen abonnement kreves. Alle nåværende og fremtidige funksjoner er inkludert, inkludert iOS- og Android-appene."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ontgrendel QuickDrop+ om bestanden onbeperkt te blijven uitwisselen. QuickDrop+ is een eenmalige aankoop – geen abonnement nodig. Alle huidige en toekomstige functies zijn inbegrepen, ook de iOS- en Android-apps."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Odblokuj QuickDrop+, aby dalej wymieniać pliki bez ograniczeń. QuickDrop+ to jednorazowy zakup – bez subskrypcji. Obejmuje wszystkie obecne i przyszłe funkcje, w tym aplikacje na iOS i Androida."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desbloqueie o QuickDrop+ para continuar trocando arquivos sem limites. O QuickDrop+ é uma compra única – sem assinatura. Todos os recursos atuais e futuros estão incluídos, incluindo os apps para iOS e Android."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desbloqueie o QuickDrop+ para continuar a trocar ficheiros sem limites. O QuickDrop+ é uma compra única – sem necessidade de subscrição. Todas as funcionalidades atuais e futuras estão incluídas, incluindo as apps para iOS e Android."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deblochează QuickDrop+ pentru a continua schimbul de fișiere fără limite. QuickDrop+ este o achiziție unică – fără abonament. Toate funcțiile actuale și viitoare sunt incluse, inclusiv aplicațiile iOS și Android."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Разблокируйте QuickDrop+, чтобы продолжать обмен файлами без ограничений. QuickDrop+ — это единоразовая покупка, подписка не требуется. Включены все текущие и будущие функции, включая приложения для iOS и Android."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lås upp QuickDrop+ för att fortsätta utbyta filer utan begränsningar. QuickDrop+ är ett engångsköp – inget abonnemang krävs. Alla nuvarande och framtida funktioner ingår, inklusive appar för iOS och Android."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ปลดล็อก QuickDrop+ เพื่อแลกเปลี่ยนไฟล์ได้ไม่จำกัด QuickDrop+ ซื้อครั้งเดียว ไม่มีค่าบริการรายเดือน รวมฟีเจอร์ปัจจุบันและอนาคตทั้งหมด ทั้งแอป iOS และ Android"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dosya alışverişine sınırsız devam etmek için QuickDrop+’ı açın. QuickDrop+ tek seferlik bir satın almadır – abonelik gerekmez. iOS ve Android uygulamaları da dahil olmak üzere mevcut ve gelecekteki tüm özellikler dahildir."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Розблокуйте QuickDrop+, щоб і надалі обмінюватися файлами без обмежень. QuickDrop+ купується один раз — без підписок. Усі поточні та майбутні функції входять у покупку, включаючи додатки для iOS і Android."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mở khóa QuickDrop+ để tiếp tục trao đổi tệp không giới hạn. QuickDrop+ là mua một lần – không cần đăng ký. Bao gồm tất cả tính năng hiện tại và tương lai, cùng với ứng dụng iOS và Android."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "解锁 QuickDrop+，即可无限制传输文件。QuickDrop+ 为一次性购买，无需订阅。所有当前和未来功能均已包含，包括 iOS 和 Android 应用。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "解鎖 QuickDrop+ 以無限交換檔案。QuickDrop+ 僅需一次性購買，無需訂閱。所有現有和未來功能均包含在內，包括 iOS 和 Android 應用程式。"
          }
        }
      }
    },
