    "QrCodeInstructions" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "امسح رمز QR باستخدام جهاز Android الخاص بك لربطه بهذا الجهاز. تأكد من أن هاتفك متصل بنفس الشبكة.\n\nإذا لم ترغب في مسح رمز QR في كل مرة ترسل فيها ملفًا، قم بتثبيت تطبيق QuickDrop (انظر أعلاه)."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Escaneja el codi QR amb el teu dispositiu Android per connectar-lo a aquest dispositiu. Assegura't que el teu telèfon estigui connectat a la mateixa xarxa.\n\nSi no vols escanejar el codi QR per a cada transferència de fitxers, instal·la l'app QuickDrop (vegeu més amunt)."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Naskenujte QR kód svým Androidem pro připojení k tomuto zařízení. Ujistěte se, že je telefon připojen ke stejné síti.\n\nPokud nechcete skenovat QR kód při každém přenosu, nainstalujte si aplikaci QuickDrop (viz výše)."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scan QR-koden med din Android-enhed for at forbinde den til denne enhed. Sørg for, at din telefon er tilsluttet det samme netværk.\n\nHvis du ikke vil scanne QR-koden for hver filoverførsel, så installer QuickDrop-appen (se ovenfor)."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scanne den QR-Code mit deinem Android-Gerät, um eine Verbindung zu diesem Gerät herzustellen. Stelle sicher, dass dein Handy mit demselben Netzwerk verbunden ist.\n\nWenn du nicht bei jeder Dateiübertragung den QR-Code scannen möchtest, installiere die QuickDrop-App (siehe oben)."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Σαρώστε τον κωδικό QR με την Android συσκευή σας για να τη συνδέσετε με αυτή τη συσκευή. Βεβαιωθείτε ότι το κινητό σας είναι συνδεδεμένο στο ίδιο δίκτυο.\n\nΕάν δεν θέλετε να σαρώσετε τον κωδικό QR για κάθε μεταφορά αρχείου, εγκαταστήστε την εφαρμογή QuickDrop (δείτε παραπάνω)."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Use your Android device to scan the QR code and connect to this device. Make sure both devices are on the same network.\n\nFor easier transfers, install the QuickDrop app (see above)."
          }
        },
        "en-AU" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scan the QR code with your Android device to connect it to this device. Make sure your phone is connected to the same network.\n\nIf you don’t want to scan the QR code for every file transfer, install the QuickDrop app (see above)."
          }
        },
        "en-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scan the QR code with your Android device to connect it to this device. Make sure your phone is on the same network.\n\nIf you don’t want to scan the QR code every time you transfer a file, install the QuickDrop app (see above)."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scan the QR Code with your Android device to connect it to this device. Ensure your phone is on the same network.\n\nIf you’d prefer not to scan the QR code every time you transfer a file, install the QuickDrop app (see above)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Escanea el código QR con tu dispositivo Android para conectarlo a este dispositivo. Asegúrate de que tu teléfono esté conectado a la misma red.\n\nSi no quieres escanear el código QR cada vez que transfieras un archivo, instala la app QuickDrop (ver arriba)."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Escanea el código QR con tu dispositivo Android para conectarlo a este dispositivo. Asegúrate de que tu teléfono esté conectado a la misma red.\n\nSi no deseas escanear el código QR para cada transferencia de archivo, instala la app de QuickDrop (ver arriba)."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Skannaa QR-koodi Android-laitteellasi yhdistääksesi sen tähän laitteeseen. Varmista, että puhelimesi on yhdistetty samaan verkkoon.\n\nJos et halua skannata QR-koodia jokaista tiedostonsiirtoa varten, asenna QuickDrop-sovellus (katso yllä)."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scannez le code QR avec votre appareil Android pour le connecter à cet appareil. Assurez-vous que votre téléphone est connecté au même réseau.\n\nSi vous ne souhaitez pas scanner le code QR à chaque transfert de fichier, installez l'application QuickDrop (voir ci-dessus)."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scannez le code QR avec votre appareil Android pour le connecter à cet appareil. Assurez-vous que votre téléphone est connecté au même réseau.\n\nSi vous ne voulez pas scanner le code QR à chaque transfert de fichier, installez l’application QuickDrop (voir ci-dessus)."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "סרוק את קוד ה-QR עם מכשיר האנדרואיד שלך כדי להתחבר למחשב זה. ודא שהטלפון שלך מחובר לאותה רשת.\n\nאם אינך רוצה לסרוק קוד QR בכל העברת קבצים, התקן את אפליקציית QuickDrop (ראה למעלה)."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अपने Android डिवाइस से QR कोड स्कैन करें ताकि इसे इस डिवाइस से जोड़ सकें। सुनिश्चित करें कि आपका फ़ोन उसी नेटवर्क से जुड़ा है।\n\nअगर आप हर बार फाइल ट्रांसफर के लिए QR कोड स्कैन नहीं करना चाहते, तो QuickDrop ऐप इंस्टॉल करें (ऊपर देखें)।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Skenirajte QR kod svojim Android uređajem kako biste ga povezali s ovim uređajem. Provjerite je li vaš telefon spojen na istu mrežu.\n\nAko ne želite skenirati QR kod pri svakom prijenosu datoteka, instalirajte aplikaciju QuickDrop (pogledajte gore)."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Olvasd be a QR-kódot Android-készülékeddel, hogy csatlakoztasd ehhez az eszközhöz. Győződj meg róla, hogy telefonod ugyanahhoz a hálózathoz csatlakozik.\n\nHa nem szeretnéd minden fájlátvitelhez leolvasni a QR-kódot, telepítsd a QuickDrop alkalmazást (lásd fentebb)."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pindai kode QR dengan perangkat Android Anda untuk menghubungkannya ke perangkat ini. Pastikan ponsel Anda terhubung ke jaringan yang sama.\n\nJika Anda tidak ingin memindai kode QR setiap kali transfer file, instal aplikasi QuickDrop (lihat di atas)."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scansiona il codice QR con il tuo dispositivo Android per collegarlo a questo dispositivo. Assicurati che il telefono sia connesso alla stessa rete.\n\nSe non vuoi scansionare il codice QR a ogni trasferimento, installa l'app QuickDrop (vedi sopra)."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Android端末でQRコードをスキャンして、このデバイスと接続してください。スマートフォンが同じネットワークに接続されていることを確認してください。\n\n毎回ファイル転送のたびにQRコードをスキャンしたくない場合は、QuickDropアプリをインストールしてください（上記参照）。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Android 기기로 QR 코드를 스캔해 이 기기와 연결하세요. 휴대폰이 동일한 네트워크에 연결되어 있는지 확인하세요.\n\n매번 QR 코드를 스캔하지 않고 파일을 전송하려면 QuickDrop 앱을 설치하세요(위 안내 참고)."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Imbas Kod QR dengan peranti Android anda untuk sambungkan ke peranti ini. Pastikan telefon anda disambungkan ke rangkaian yang sama.\n\nJika anda tidak mahu imbas Kod QR setiap kali pindahan fail, pasang aplikasi QuickDrop (lihat di atas)."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Skann QR-koden med Android-enheten din for å koble den til denne enheten. Pass på at telefonen er tilkoblet det samme nettverket.\n\nHvis du ikke vil skanne QR-koden for hver filoverføring, installer QuickDrop-appen (se over)."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scan de QR-code met je Android-toestel om deze te koppelen aan dit apparaat. Zorg dat je telefoon met hetzelfde netwerk is verbonden.\n\nWil je niet elke keer de QR-code scannen, installeer dan de QuickDrop-app (zie hierboven)."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zeskanuj kod QR swoim urządzeniem z Androidem, aby połączyć je z tym urządzeniem. Upewnij się, że Twój telefon jest podłączony do tej samej sieci.\n\nJeśli nie chcesz skanować kodu QR przy każdym przesyłaniu plików, zainstaluj aplikację QuickDrop (patrz powyżej)."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Escaneie o código QR com seu dispositivo Android para conectá-lo a este dispositivo. Certifique-se de que seu telefone está conectado à mesma rede.\n\nSe não quiser escanear o código QR a cada transferência de arquivo, instale o aplicativo QuickDrop (veja acima)."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Digitalize o código QR com o seu dispositivo Android para o ligar a este aparelho. Certifique-se de que o seu telemóvel está ligado à mesma rede.\n\nSe não quiser digitalizar o código QR em cada transferência, instale a app QuickDrop (ver acima)."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scanează codul QR cu dispozitivul tău Android pentru a-l conecta la acest dispozitiv. Asigură-te că telefonul este conectat la aceeași rețea.\n\nDacă nu vrei să scanezi codul QR la fiecare transfer de fișiere, instalează aplicația QuickDrop (vezi mai sus)."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Отсканируйте QR-код с помощью вашего Android-устройства, чтобы подключить его к этому компьютеру. Убедитесь, что телефон подключён к той же сети.\n\nЕсли не хотите сканировать QR-код перед каждой передачей файла, установите приложение QuickDrop (см. выше)."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Skanna QR-koden med din Android-enhet för att ansluta den till denna enhet. Se till att din telefon är ansluten till samma nätverk.\n\nOm du inte vill skanna QR-koden vid varje filöverföring, installera QuickDrop-appen (se ovan)."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "สแกน QR โค้ดด้วยอุปกรณ์ Android ของคุณเพื่อเชื่อมต่อกับอุปกรณ์นี้ ตรวจสอบว่าโทรศัพท์ของคุณเชื่อมต่อกับเครือข่ายเดียวกัน\n\nหากไม่ต้องการสแกน QR โค้ดทุกครั้งที่โอนไฟล์ ให้ติดตั้งแอป QuickDrop (ดูด้านบน)"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bağlantı kurmak için Android cihazınızla QR Kodunu tarayın. Telefonunuzun aynı ağa bağlı olduğundan emin olun.\n\nHer dosya aktarımı için QR kodunu tekrar taramak istemiyorsanız, QuickDrop uygulamasını yükleyin (yukarıya bakın)."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Скануйте QR-код на вашому Android, щоб підключити його до цього пристрою. Переконайтеся, що телефон у тій самій мережі.\n\nЩоб не сканувати QR-код для кожної передачі, встановіть додаток QuickDrop (див. вище)."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quét mã QR bằng thiết bị Android của bạn để kết nối với thiết bị này. Đảm bảo điện thoại của bạn đã kết nối cùng mạng.\n\nNếu bạn không muốn quét mã QR mỗi lần chuyển tệp, hãy cài đặt ứng dụng QuickDrop (xem phía trên)."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "用您的 Android 设备扫描二维码，将其连接到此设备。确保手机连接在同一网络。\n\n如果不想每次传输文件都扫描二维码，请安装 QuickDrop 应用（见上方）。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "用您的 Android 手機掃描 QR 碼即可連接此裝置。請確保手機連接在同一個網路。\n\n如果您不想每次傳檔都掃描 QR 碼，請安裝 QuickDrop 應用程式（詳見上方）。"
          }
        }
      }
    },
    "QrCodeInstructionsApp" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لربط هذا الجهاز بجهاز Android الخاص بك، افتح تطبيق QuickDrop على جهاز Android. تأكد من أن هاتفك متصل بنفس الشبكة.\n\nلتثبيت QuickDrop على هاتفك، امسح رمز QR ضوئيًا أو ابحث عن 'QuickDrop' في متجر Google Play."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Per connectar aquest dispositiu al teu dispositiu Android, obre l'app QuickDrop al teu Android. Assegura't que el telèfon estigui connectat a la mateixa xarxa.\n\nPer instal·lar QuickDrop al teu telèfon, escaneja el codi QR o busca 'QuickDrop' a Google Play Store."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chcete-li připojit toto zařízení k vašemu Androidu, otevřete na telefonu aplikaci QuickDrop. Ujistěte se, že je telefon připojen ke stejné síti.\n\nPro instalaci QuickDrop na váš telefon naskenujte QR kód nebo vyhledejte 'QuickDrop' v Obchodě Play."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "For at forbinde denne enhed til din Android-enhed, skal du åbne QuickDrop-appen på din Android-enhed. Sørg for, at din telefon er tilsluttet det samme netværk.\n\nFor at installere QuickDrop på din telefon, scan QR-koden eller søg efter 'QuickDrop' i Google Play Butik."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Um dieses Gerät mit deinem Android-Gerät zu verbinden, öffne die QuickDrop-App auf deinem Android-Gerät. Stelle sicher, dass dein Handy mit demselben Netzwerk verbunden ist.\n\nUm QuickDrop auf deinem Handy zu installieren, scanne den QR-Code oder suche im Google Play Store nach 'QuickDrop'."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Για να συνδέσετε αυτή τη συσκευή με την Android συσκευή σας, ανοίξτε την εφαρμογή QuickDrop στο Android σας. Βεβαιωθείτε ότι το κινητό σας είναι συνδεδεμένο στο ίδιο δίκτυο.\n\nΓια να εγκαταστήσετε το QuickDrop στο κινητό σας, σαρώστε τον κωδικό QR ή αναζητήστε 'QuickDrop' στο Google Play Store."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "To link this device with your Android, open the QuickDrop app on your Android and ensure your phone is on the same network.\n\nTo get QuickDrop on your phone, scan the QR code or search 'QuickDrop' in the Google Play Store."
          }
        },
        "en-AU" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "To connect this device to your Android device, open the QuickDrop app on your Android. Make sure your phone is connected to the same network.\n\nTo install QuickDrop on your phone, scan the QR code or search for ‘QuickDrop’ on the Google Play Store."
          }
        },
        "en-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "To connect this device to your Android device, open the QuickDrop app on your Android device. Make sure your phone is on the same network.\n\nTo install QuickDrop on your phone, scan the QR code or search for 'QuickDrop' in the Google Play Store."
          }
        },
        "en-GB" : {
          "stringUnit" : {
