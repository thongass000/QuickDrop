          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A QuickDrop mostantól különálló alkalmazásként is elérhető az okostelefonodhoz! Az alkalmazás további funkciókat kínál, például a fájlok átvitelének lehetőségét, amikor nem vagy csatlakozva az otthoni Wi-Fi hálózathoz, a Mac és az okostelefonod hotspotjának összekapcsolásával.\n\nA QuickDrop telepítéséhez a telefonodra olvasd be a QR-kódot, vagy keresd meg a 'QuickDrop' alkalmazást a Google Play Áruházban."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
