    "introduction_local_network_access_description" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "variations" : {
            "device" : {
              "mac" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "يحتاج QuickDrop إلى إذن الوصول للشبكة المحلية لنقل الملفات عبر Wi-Fi. انقر على \"%@\" لمنح هذا الإذن."
                }
              },
              "other" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "يحتاج QuickDrop إلى إذن الوصول للشبكة المحلية لنقل الملفات عبر Wi-Fi. اضغط على \"%@\" لمنح هذا الإذن."
                }
              }
            }
          }
        },
        "ca" : {
          "variations" : {
            "device" : {
              "mac" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "QuickDrop necessita accés a la xarxa local per transmetre fitxers per Wi-Fi. Fes clic a «%@» per concedir aquest permís."
                }
              },
              "other" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "QuickDrop necessita accés a la xarxa local per transmetre fitxers per Wi-Fi. Toca «%@» per concedir aquest permís."
                }
              }
            }
          }
        },
        "cs" : {
          "variations" : {
            "device" : {
              "mac" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "QuickDrop potřebuje přístup k místní síti pro přenos souborů přes vaše Wi-Fi. Klikněte na „%@“ pro udělení tohoto oprávnění."
                }
              },
              "other" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "QuickDrop potřebuje přístup k místní síti pro přenos souborů přes vaše Wi-Fi. Klepněte na „%@“ pro udělení tohoto oprávnění."
                }
              }
            }
          }
        },
        "da" : {
          "variations" : {
            "device" : {
              "mac" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "QuickDrop har brug for lokal netværksadgang for at overføre filer via dit Wi-Fi. Klik på “%@” for at give tilladelsen."
                }
              },
              "other" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "QuickDrop har brug for lokal netværksadgang for at overføre filer via dit Wi-Fi. Tryk på “%@” for at give tilladelsen."
                }
              }
            }
          }
        },
        "de" : {
          "variations" : {
            "device" : {
              "mac" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "QuickDrop benötigt Zugriff auf das lokale Netzwerk, um Dateien über dein WLAN zu übertragen. Klicke auf „%@“, um dies zu erlauben."
                }
              },
              "other" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "QuickDrop benötigt Zugriff auf das lokale Netzwerk, um Dateien über dein WLAN zu übertragen. Tippe auf „%@“, um dies zu erlauben."
                }
              }
            }
          }
        },
        "el" : {
