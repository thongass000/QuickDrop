    "introduction_finished_description" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أصبح QuickDrop جاهزًا للاستخدام الآن. لمعرفة المزيد عن QuickDrop وتعديل الإعدادات، اضغط على متابعة. شكرًا لاستخدامك QuickDrop!"
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop ja està llest per utilitzar-se. Per saber-ne més i modificar la configuració, fes clic a Continua. Gràcies per utilitzar QuickDrop!"
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop je nyní připraven k použití. Chcete-li se dozvědět více o QuickDropu a upravit nastavení, klikněte na Pokračovat. Děkujeme, že používáte QuickDrop!"
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop er nu klar til brug. For at lære mere om QuickDrop og ændre indstillinger, klik på Fortsæt. Tak fordi du bruger QuickDrop!"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop ist jetzt einsatzbereit. Um mehr über QuickDrop zu erfahren und Einstellungen zu ändern, klicke auf „Weiter“. Danke, dass Du QuickDrop nutzt!"
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Το QuickDrop είναι έτοιμο για χρήση. Για να μάθετε περισσότερα και να αλλάξετε ρυθμίσεις, κάντε κλικ στο Συνέχεια. Ευχαριστούμε που χρησιμοποιείτε το QuickDrop!"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop is now ready to be used. To learn more about QuickDrop and modify settings, click on Continue. Thanks for using QuickDrop!"
          }
        },
        "en-AU" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop is now ready to be used. To learn more about QuickDrop and modify settings, click on Continue. Thanks for using QuickDrop!"
          }
        },
        "en-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop is now ready to be used. To learn more about QuickDrop and modify settings, click on Continue. Thanks for using QuickDrop!"
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop is now ready to be used. To learn more about QuickDrop and modify settings, click on Continue. Thanks for using QuickDrop!"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop ya está listo para usarse. Para saber más sobre QuickDrop y modificar la configuración, haz clic en Continuar. ¡Gracias por usar QuickDrop!"
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop ya está listo para usarse. Para saber más sobre QuickDrop y modificar la configuración, haz clic en Continuar. ¡Gracias por usar QuickDrop!"
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop on nyt valmis käytettäväksi. Saat lisätietoja ja voit muokata asetuksia napsauttamalla Jatka. Kiitos, että käytät QuickDropia!"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop est maintenant prêt à être utilisé. Pour en savoir plus sur QuickDrop et modifier les paramètres, cliquez sur Continuer. Merci d’utiliser QuickDrop !"
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop est maintenant prêt à être utilisé. Pour en savoir plus sur QuickDrop et modifier les paramètres, cliquez sur Continuer. Merci d’utiliser QuickDrop!"
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop מוכן לשימוש. כדי ללמוד עוד על QuickDrop ולשנות הגדרות, לחץ על המשך. תודה שאתה משתמש ב-QuickDrop!"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop अब उपयोग के लिए तैयार है। QuickDrop के बारे में अधिक जानने और सेटिंग्स बदलने के लिए 'जारी रखें' पर क्लिक करें। QuickDrop उपयोग करने के लिए धन्यवाद!"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop je sada spreman za korištenje. Za više informacija o QuickDropu i promjenu postavki, kliknite na Nastavi. Hvala što koristite QuickDrop!"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A QuickDrop most már használatra kész. Ha többet szeretne megtudni a QuickDropról vagy módosítani a beállításokat, kattintson a Tovább gombra. Köszönjük, hogy a QuickDropot használja!"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop siap digunakan. Untuk mempelajari lebih lanjut tentang QuickDrop dan mengubah pengaturan, klik Lanjutkan. Terima kasih telah menggunakan QuickDrop!"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop è ora pronto per l'uso. Per saperne di più su QuickDrop e modificare le impostazioni, fai clic su Continua. Grazie per aver scelto QuickDrop!"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDropの準備ができました。詳細や設定変更は「続ける」をクリックしてください。ご利用ありがとうございます！"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop을 사용할 준비가 되었습니다. QuickDrop에 대해 더 알아보고 설정을 변경하려면 계속 버튼을 클릭하세요. QuickDrop을 이용해 주셔서 감사합니다!"
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop kini sedia digunakan. Untuk mengetahui lebih lanjut tentang QuickDrop dan mengubah tetapan, klik Teruskan. Terima kasih kerana menggunakan QuickDrop!"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop er nå klar til bruk. For å lære mer om QuickDrop og endre innstillinger, klikk på Fortsett. Takk for at du bruker QuickDrop!"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop is nu klaar voor gebruik. Klik op Doorgaan om meer te weten te komen over QuickDrop en de instellingen aan te passen. Bedankt voor het gebruik van QuickDrop!"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop jest gotowy do użycia. Aby dowiedzieć się więcej o QuickDrop i zmienić ustawienia, kliknij Kontynuuj. Dziękujemy za korzystanie z QuickDrop!"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O QuickDrop está pronto para uso. Para saber mais sobre o QuickDrop e ajustar as configurações, clique em Continuar. Obrigado por usar o QuickDrop!"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O QuickDrop está pronto a ser utilizado. Para saber mais sobre o QuickDrop e alterar definições, clique em Continuar. Obrigado por usar o QuickDrop!"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop este acum gata de utilizare. Pentru a afla mai multe despre QuickDrop și a modifica setările, fă clic pe Continuă. Mulțumim că folosești QuickDrop!"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop готов к использованию. Чтобы узнать больше о QuickDrop и изменить настройки, нажмите «Продолжить». Спасибо за использование QuickDrop!"
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop är nu redo att användas. För att lära dig mer om QuickDrop och ändra inställningar, klicka på Fortsätt. Tack för att du använder QuickDrop!"
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop พร้อมใช้งานแล้ว หากต้องการเรียนรู้เพิ่มเติมหรือปรับการตั้งค่า ให้คลิกดำเนินการต่อ ขอบคุณที่ใช้ QuickDrop!"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop artık kullanıma hazır. QuickDrop hakkında daha fazla bilgi almak ve ayarları değiştirmek için Devam’a tıklayın. QuickDrop kullandığınız için teşekkürler!"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop готовий до використання. Щоб дізнатися більше та змінити налаштування, натисніть «Продовжити». Дякуємо, що користуєтесь QuickDrop!"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop đã sẵn sàng để sử dụng. Để tìm hiểu thêm về QuickDrop và thay đổi cài đặt, hãy nhấn Tiếp tục. Cảm ơn bạn đã sử dụng QuickDrop!"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop 现已准备就绪。要了解更多信息或修改设置，请点击“继续”。感谢您使用 QuickDrop！"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop 已準備就緒。若想進一步了解 QuickDrop 並修改設定，請點選「繼續」。感謝您使用 QuickDrop！"
          }
        }
      }
    },
