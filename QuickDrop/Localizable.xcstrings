    "TimeoutDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "افتح إعدادات النظام، واذهب إلى \"الخصوصية والأمان\" > \"الشبكة المحلية\". تأكد من تفعيل QuickDrop.\n\nبالإضافة إلى ذلك، افتح إعدادات جهاز Android وابحث عن 'Quick Share'. غيّر إعداد 'من يمكنه المشاركة معك' إلى 'الجميع'، ثم حاول مرة أخرى."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Obre la Configuració del sistema i ves a «Privadesa i seguretat» > «Xarxa local». Assegura't que QuickDrop estigui activat.\n\nA més, obre la configuració del teu dispositiu Android i cerca 'Quick Share'. Canvia l'opció 'Qui pot compartir amb tu' a 'Tothom', i torna-ho a intentar."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Otevřete Systémová nastavení a přejděte na „Ochrana soukromí a zabezpečení“ > „Místní síť“. Ujistěte se, že je QuickDrop povolený.\n\nTaké otevřete nastavení vašeho Android zařízení a vyhledejte 'Quick Share'. Změňte nastavení 'Kdo s vámi může sdílet' na 'Všichni' a zkuste to znovu."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Åbn Systemindstillinger, og gå til \"Privatliv & Sikkerhed\" > \"Lokalt netværk\". Sørg for, at QuickDrop er aktiveret.\n\nÅbn desuden indstillingerne på din Android-enhed og søg efter 'Quick Share'. Skift indstillingen 'Hvem kan dele med dig' til 'Alle', og prøv igen."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Öffne die Systemeinstellungen und gehe zu „Datenschutz & Sicherheit“ > „Lokales Netzwerk“. Stelle sicher, dass QuickDrop aktiviert ist.\n\nÖffne außerdem die Einstellungen auf deinem Android-Gerät und suche nach „Quick Share“. Setze die Option „Wer kann mit dir teilen“ auf „Jeder“ und versuche es erneut."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ανοίξτε τις Ρυθμίσεις Συστήματος και πηγαίνετε στο «Απόρρητο & Ασφάλεια» > «Τοπικό Δίκτυο». Βεβαιωθείτε ότι το QuickDrop είναι ενεργοποιημένο.\n\nΕπιπλέον, ανοίξτε τις ρυθμίσεις της Android συσκευής σας και αναζητήστε 'Quick Share'. Αλλάξτε τη ρύθμιση «Ποιος μπορεί να μοιράζεται μαζί σας» σε «Όλοι» και δοκιμάστε ξανά."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Open System Settings, and go to \"Privacy & Security\" > \"Local Network\". Make sure that QuickDrop is enabled.\n\nIn addition, please open the settings of your Android device and search for 'Quick Share'. Change the setting 'Who can share with you' to 'Everyone', and try again."
          }
        },
        "en-AU" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Open System Settings, and go to \"Privacy & Security\" > \"Local Network\". Make sure that QuickDrop is enabled.\n\nIn addition, please open the settings of your Android device and search for 'Quick Share'. Change the setting 'Who can share with you' to 'Everyone', and try again."
          }
        },
        "en-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Open System Settings, and go to \"Privacy & Security\" > \"Local Network.\" Ensure that QuickDrop is enabled.\n\nAlso, please open the settings on your Android device and search for 'Quick Share.' Set 'Who can share with you' to 'Everyone,' and try again."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Open System Settings, and go to \"Privacy & Security\" > \"Local Network\". Make sure that QuickDrop is enabled.\n\nIn addition, please open the settings of your Android device and search for 'Quick Share'. Change the setting 'Who can share with you' to 'Everyone', and try again."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abre Configuración del sistema y ve a \"Privacidad y seguridad\" > \"Red local\". Asegúrate de que QuickDrop esté activado.\n\nAdemás, abre los ajustes de tu dispositivo Android y busca 'Quick Share'. Cambia la opción 'Quién puede compartir contigo' a 'Todos' e inténtalo de nuevo."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abre los Ajustes del sistema y ve a \"Privacidad y seguridad\" > \"Red local\". Asegúrate de que QuickDrop esté activado.\n\nAdemás, abre los ajustes de tu dispositivo Android y busca 'Quick Share'. Cambia la opción 'Quién puede compartir contigo' a 'Todos', e inténtalo de nuevo."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Avaa Järjestelmäasetukset ja mene kohtaan \"Yksityisyys & turvallisuus\" > \"Lähiverkko\". Varmista, että QuickDrop on käytössä.\n\nAvaa lisäksi Android-laitteesi asetukset ja etsi 'Quick Share'. Vaihda asetus 'Kuka voi jakaa kanssasi' kohtaan 'Kaikki' ja yritä uudelleen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ouvrez les Réglages Système, puis allez dans « Confidentialité et sécurité » > « Réseau local ». Assurez-vous que QuickDrop est activé.\n\nEnsuite, ouvrez les paramètres de votre appareil Android et recherchez « Quick Share ». Modifiez l’option « Qui peut partager avec vous » sur « Tout le monde », puis réessayez."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ouvrez les Réglages du système, puis allez à « Confidentialité et sécurité » > « Réseau local ». Assurez-vous que QuickDrop est activé.\n\nDe plus, ouvrez les paramètres de votre appareil Android et recherchez « Quick Share ». Changez l’option « Qui peut partager avec vous » à « Tout le monde », puis réessayez."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "פתח את הגדרות המערכת ועבור אל \"פרטיות ואבטחה\" > \"רשת מקומית\". ודא ש-QuickDrop מופעל.\n\nבנוסף, פתח את ההגדרות של מכשיר האנדרואיד שלך וחפש 'Quick Share'. שנה את ההגדרה 'מי יכול לשתף איתך' ל-'כולם', ונסה שוב."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "सिस्टम सेटिंग्स खोलें, फिर \"प्राइवेसी और सिक्योरिटी\" > \"लोकल नेटवर्क\" पर जाएँ। सुनिश्चित करें कि QuickDrop चालू है।\n\nसाथ ही, अपने Android डिवाइस की सेटिंग्स खोलें और 'Quick Share' खोजें। 'आपसे कौन शेयर कर सकता है' सेटिंग को 'Everyone' पर सेट करें और फिर से प्रयास करें।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Otvorite Postavke sustava, zatim idite na \"Privatnost i sigurnost\" > \"Mreža u lokalnoj mreži\". Provjerite je li QuickDrop omogućen.\n\nTakođer, otvorite postavke svog Android uređaja i potražite 'Quick Share'. Postavite opciju 'Tko vam može dijeliti' na 'Svi' i pokušajte ponovno."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nyisd meg a Rendszerbeállításokat, majd menj a \"Biztonság és adatvédelem\" > \"Helyi hálózat\" menüpontra. Győződj meg róla, hogy a QuickDrop engedélyezve van.\n\nTovábbá nyisd meg Android készülékeden a beállításokat, keresd meg a 'Quick Share'-t, és állítsd a 'Ki oszthat meg veled?' beállítást 'Mindenki'-re, majd próbáld újra."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Buka Pengaturan Sistem, lalu pergi ke \"Privasi & Keamanan\" > \"Jaringan Lokal\". Pastikan QuickDrop diaktifkan.\n\nSelain itu, buka pengaturan di perangkat Android Anda dan cari 'Quick Share'. Ubah pengaturan 'Siapa yang dapat berbagi dengan Anda' menjadi 'Semua orang', lalu coba lagi."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apri le Impostazioni di Sistema e vai su \"Privacy e Sicurezza\" > \"Rete Locale\". Assicurati che QuickDrop sia attivo.\n\nInoltre, apri le impostazioni del tuo dispositivo Android e cerca 'Quick Share'. Cambia l'impostazione 'Chi può condividere con te' su 'Tutti', e riprova."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "システム設定を開き、「プライバシーとセキュリティ」>「ローカルネットワーク」に進んでください。QuickDropが有効になっていることを確認してください。\n\nさらに、お使いのAndroid端末の設定を開き、「Quick Share」と検索してください。「共有を許可する相手」を「全員」に変更し、再度お試しください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "시스템 설정을 열고 \"개인정보 보호 및 보안\" > \"로컬 네트워크\"로 이동하세요. QuickDrop이 활성화되어 있는지 확인하세요.\n\n또한, Android 기기의 설정을 열어 'Quick Share'를 검색하세요. '누가 나와 공유할 수 있나요' 설정을 '모두'로 변경한 후 다시 시도하세요."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Buka Tetapan Sistem, kemudian pergi ke \"Privasi & Keselamatan\" > \"Rangkaian Tempatan\". Pastikan QuickDrop diaktifkan.\n\nSelain itu, buka tetapan peranti Android anda dan cari 'Quick Share'. Tukar tetapan 'Siapa boleh berkongsi dengan anda' kepada 'Semua orang', dan cuba semula."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Åpne Systeminnstillinger, gå til «Personvern og sikkerhet» > «Lokalt nettverk». Kontroller at QuickDrop er aktivert.\n\nÅpne også innstillingene på Android-enheten din og søk etter 'Quick Share'. Endre innstillingen 'Hvem kan dele med deg' til 'Alle', og prøv igjen."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Open Systeeminstellingen en ga naar \"Privacy & Beveiliging\" > \"Lokale Netwerk\". Zorg ervoor dat QuickDrop is ingeschakeld.\n\nOpen daarnaast de instellingen op je Android-apparaat en zoek naar 'Quick Share'. Zet de instelling 'Wie kan met jou delen' op 'Iedereen' en probeer het opnieuw."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Otwórz Ustawienia systemowe i przejdź do „Prywatność i Bezpieczeństwo” > „Sieć lokalna”. Upewnij się, że QuickDrop jest włączony.\n\nNastępnie otwórz ustawienia swojego urządzenia z Androidem i wyszukaj „Quick Share”. Zmień ustawienie „Kto może udostępniać Tobie” na „Wszyscy” i spróbuj ponownie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abra as Configurações do Sistema e vá em \"Privacidade e Segurança\" > \"Rede Local\". Certifique-se de que o QuickDrop está ativado.\n\nAlém disso, abra as configurações do seu dispositivo Android e procure por 'Quick Share'. Altere a configuração 'Quem pode compartilhar com você' para 'Todos' e tente novamente."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abra as Definições do Sistema e vá a \"Privacidade e Segurança\" > \"Rede Local\". Certifique-se de que o QuickDrop está ativado.\n\nAdicionalmente, abra as definições do seu dispositivo Android e procure por 'Quick Share'. Altere a opção 'Quem pode partilhar consigo' para 'Todos' e tente novamente."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deschide Setări sistem și mergi la „Confidențialitate și securitate” > „Rețea locală”. Asigură-te că QuickDrop este activat.\n\nDe asemenea, deschide setările dispozitivului tău Android și caută „Quick Share”. Schimbă opțiunea „Cine poate partaja cu tine” la „Toată lumea” și încearcă din nou."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Откройте «Системные настройки» и перейдите в «Конфиденциальность и безопасность» > «Локальная сеть». Убедитесь, что QuickDrop включён.\n\nТакже откройте настройки вашего Android-устройства и найдите «Quick Share». Измените параметр «Кто может делиться с вами» на «Все» и попробуйте снова."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Öppna Systeminställningar och gå till \"Integritet och säkerhet\" > \"Lokalt nätverk\". Kontrollera att QuickDrop är aktiverat.\n\nÖppna dessutom inställningarna på din Android-enhet och sök efter 'Quick Share'. Ändra inställningen 'Vem kan dela med dig' till 'Alla', och försök igen."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "เปิดการตั้งค่าระบบ แล้วไปที่ \"ความเป็นส่วนตัวและความปลอดภัย\" > \"เครือข่ายภายในเครื่อง\" ตรวจสอบให้แน่ใจว่าได้เปิดใช้ QuickDrop แล้ว\n\nจากนั้น ให้เปิดการตั้งค่าบนอุปกรณ์ Android ของคุณแล้วค้นหา 'Quick Share' เปลี่ยนการตั้งค่า 'ใครส่งไฟล์ถึงคุณได้' เป็น 'ทุกคน' แล้วลองอีกครั้ง"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sistem Ayarları'nı açın ve \"Gizlilik ve Güvenlik\" > \"Yerel Ağ\" bölümüne gidin. QuickDrop'un etkin olduğundan emin olun.\n\nAyrıca, Android cihazınızda ayarları açıp 'Quick Share'ı arayın. 'Kim sizinle paylaşabilir' ayarını 'Herkes' olarak değiştirin ve tekrar deneyin."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Відкрийте Системні налаштування та перейдіть у «Конфіденційність і безпека» > «Локальна мережа». Переконайтеся, що QuickDrop увімкнено.\n\nТакож відкрийте налаштування на вашому Android-пристрої й знайдіть «Quick Share». Змініть параметр «Хто може надсилати вам» на «Усі», і спробуйте ще раз."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mở Cài đặt hệ thống, vào \"Quyền riêng tư & Bảo mật\" > \"Mạng cục bộ\". Đảm bảo đã bật QuickDrop.\n\nNgoài ra, hãy mở cài đặt trên thiết bị Android của bạn và tìm 'Quick Share'. Thay đổi mục 'Ai có thể chia sẻ với bạn' thành 'Mọi người', rồi thử lại."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "打开系统设置，进入“隐私与安全”>“本地网络”。确保已启用 QuickDrop。\n\n另外，请打开您的安卓设备设置，搜索“Quick Share”。将“谁可以与您分享”设置为“所有人”，然后重试。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "請打開系統設定，前往「隱私權與安全性」>「區域網路」。請確保已啟用 QuickDrop。\n\n此外，請在您的 Android 裝置中開啟設定，搜尋「Quick Share」。將「誰可以與您分享」設定為「所有人」，然後再試一次。"
          }
        }
      }
    },
