    "plusview_purchasefaileddescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "إذا ظهر هذا الرسالة بشكل غير متوقع، يرجى التأكد من اتصالك بالإنترنت وأن عمليات الشراء داخل التطبيق مفعّلة على جهازك، ثم حاول مرة أخرى."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si aquest missatge ha aparegut de manera inesperada, assegura't que estàs connectat a Internet i que les Compres In-App estan activades per al teu dispositiu, i prova de nou."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pokud se tato zpráva objevila neočekávaně, ověřte prosím, že jste připojeni k internetu a že jsou povolené nákupy v aplikaci pro vaše zařízení, a zkuste to znovu."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hvis denne meddelelse er vist uventet, så sørg for, at du er forbundet til internettet, og at køb i appen er aktiveret på din enhed. Prøv derefter igen."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Falls diese Nachricht unerwartet erscheint, stelle sicher, dass du mit dem Internet verbunden bist und In-App-Käufe auf deinem Gerät aktiviert sind, und versuche es erneut."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Εάν εμφανίστηκε αυτό το μήνυμα απροσδόκητα, βεβαιωθείτε ότι είστε συνδεδεμένοι στο Διαδίκτυο και ότι οι Αγορές Εντός Εφαρμογής είναι ενεργοποιημένες για τη συσκευή σας και δοκιμάστε ξανά."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If this message appeared unexpectedly, please make sure that you are connected to the Internet and In-App-Purchases are enabled for your device and then try again."
          }
        },
        "en-AU" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If this was unexpected, check you're online and In-App Purchases are active, then retry."
          }
        },
        "en-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ensure you're connected to the Internet and In-App Purchases are enabled, then retry."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If unexpected, check your internet and enable In-App Purchases before trying again."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si este mensaje apareció inesperadamente, asegúrate de estar conectado a internet y que las compras dentro de la aplicación estén habilitadas en tu dispositivo, luego intenta nuevamente."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si este mensaje apareció inesperadamente, por favor, asegúrate de estar conectado a Internet y de que las compras dentro de la app estén habilitadas para tu dispositivo e inténtalo nuevamente."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jos tämä viesti tuli odottamatta, varmista, että olet yhdistetty internetiin ja sovelluksen sisäiset ostot ovat käytössä laitteellasi, ja yritä uudelleen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si ce message est apparu de manière inattendue, assurez-vous d'être connecté à Internet et que les achats intégrés sont activés sur votre appareil, puis réessayez."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si ce message est apparu de manière inattendue, veuillez vous assurer que vous êtes connecté à Internet et que les achats intégrés sont activés pour votre appareil, puis réessayez."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "אם הודעה זו הופיעה באופן בלתי צפוי, ודא שאתה מחובר לאינטרנט ורכישות מתוך האפליקציה מופעלות במכשיר שלך, ואז נסה שוב."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यदि यह संदेश अनपेक्षित रूप से दिखाई दिया, तो यह सुनिश्चित करें कि आप इंटरनेट से जुड़े हैं और आपके डिवाइस के लिए इन-ऐप-खरीदारी सक्षम है, फिर पुनः प्रयास करें।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ako se ova poruka pojavila neočekivano, provjerite jeste li povezani na internet i je li omogućen In-App-Kupnje na vašem uređaju, zatim pokušajte ponovno."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ha ez az üzenet váratlanul jelent meg, ellenőrizd az internetkapcsolatot, és győződj meg róla, hogy az alkalmazáson belüli vásárlások engedélyezve vannak az eszközödön, majd próbáld újra."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jika pesan ini muncul secara tak terduga, pastikan bahwa Anda terhubung ke Internet dan Pembelian Dalam Aplikasi diaktifkan untuk perangkat Anda dan kemudian coba lagi."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se questo messaggio è apparso inaspettatamente, assicurati di essere connesso a Internet e che gli acquisti in-app siano abilitati sul tuo dispositivo, quindi riprova."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このメッセージが予期せず表示された場合、インターネット接続を確認し、アプリ内購入が有効になっていることを確認した上で再試行してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 메시지가 예상치 않게 나타난 경우, 인터넷에 연결되어 있는지 확인하고 기기에서 인앱 결제가 활성화되어 있는지 확인한 후 다시 시도해 주세요."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jika mesej ini muncul secara tidak diduga, pastikan bahawa anda disambungkan ke Internet dan Pembelian Dalam Aplikasi diaktifkan untuk peranti anda, kemudian cuba lagi."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hvis denne meldingen dukket opp uventet, sørg for at du er koblet til Internett og at kjøp i app er aktivert for enheten din, og prøv igjen."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Als dit bericht onverwachts verschijnt, controleer dan of je verbonden bent met internet en of in-app aankopen zijn ingeschakeld op je apparaat, en probeer het opnieuw."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jeśli ten komunikat pojawił się niespodziewanie, upewnij się, że masz dostęp do Internetu i włączone zakupy w aplikacji, a następnie spróbuj ponownie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se esta mensagem apareceu inesperadamente, verifique se você está conectado à internet e se as compras dentro do app estão ativadas no seu dispositivo e tente novamente."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se esta mensagem apareceu inesperadamente, certifique-se de estar conectado à Internet e que as compras dentro do app estejam ativadas no seu dispositivo, depois tente novamente."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dacă acest mesaj a apărut neașteptat, asigură-te că ești conectat la internet și că achizițiile în aplicație sunt activate pe dispozitivul tău, apoi încearcă din nou."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Если это сообщение появилось неожиданно, убедитесь, что у вас есть доступ к интернету и включены встроенные покупки на вашем устройстве, затем попробуйте снова."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Om detta meddelande dök upp oväntat, kontrollera att du är ansluten till internet och att In-App-köp är aktiverade på din enhet och försök sedan igen."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "หากข้อความนี้ปรากฏขึ้นโดยไม่คาดคิด โปรดตรวจสอบว่าคุณเชื่อมต่ออินเทอร์เน็ตและเปิดใช้งานการซื้อภายในแอปในอุปกรณ์ของคุณแล้วลองอีกครั้ง"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu mesaj beklenmedik biçimde belirdiyse, lütfen internete bağlı olduğunuzdan ve cihazınızda Uygulama İçi Satın Alımların etkin olduğundan emin olun ve tekrar deneyin."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Якщо це повідомлення з’явилося несподівано, переконайтеся, що у вас є підключення до Інтернету, а покупки в додатках увімкнені на вашому пристрої, і спробуйте ще раз."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nếu thông báo này xuất hiện bất ngờ, vui lòng đảm bảo bạn đang kết nối Internet và Mua hàng trong Ứng dụng được bật cho thiết bị của bạn, sau đó thử lại."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果此消息意外出现，请确保您已连接到互联网，并且设备已启用应用内购买功能，然后重试。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果此訊息意外出現，請確保您已連接到互聯網並且應用內購買已為裝置啟用，然後重試。"
          }
        }
      }
    },
