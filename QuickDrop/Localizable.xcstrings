            "device" : {
              "mac" : {
                "stringUnit" : {
                  "state" : "translated",
                  "value" : "Το QuickDrop χρειάζεται πρόσβαση στο τοπικό δίκτυο για μεταφορά αρχείων μέσω Wi-Fi. Κάντε κλικ στο «%@» για να δώσετε άδεια."
                }
