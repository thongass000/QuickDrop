        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous avez refusé l'accès au réseau local pour QuickDrop. QuickDrop ne peut pas fonctionner sans cette autorisation. Cliquez ici pour accorder l'accès au réseau local."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "סירבת לגישה לרשת המקומית עבור QuickDrop. QuickDrop אינו יכול לעבוד ללא אישור זה. לחץ כאן כדי להעניק גישה לרשת המקומית."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आपने QuickDrop के लिए स्थानीय नेटवर्क एक्सेस से इनकार कर दिया है। इस अनुमति के बिना QuickDrop कार्य नहीं कर सकता। स्थानीय नेटवर्क एक्सेस देने के लिए यहां क्लिक करें।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Odbili ste lokalni pristup mreži za QuickDrop. QuickDrop ne može raditi bez ovog dopuštenja. Kliknite ovdje za dodjelu lokalnog mrežnog pristupa."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ön megtagadta a helyi hálózathoz való hozzáférést a QuickDrop számára. A QuickDrop nem működik ezen engedély nélkül. Kattintson ide a helyi hálózathoz való hozzáférés engedélyezéséhez."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anda menolak akses jaringan lokal untuk QuickDrop. QuickDrop tidak dapat bekerja tanpa izin ini. Klik di sini untuk memberikan akses jaringan lokal."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hai negato l'accesso alla rete locale per QuickDrop. QuickDrop non può funzionare senza questa autorizzazione. Clicca qui per concedere l'accesso alla rete locale."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDropのローカルネットワークアクセスが拒否されました。この権限がないとQuickDropは動作しません。ローカルネットワークアクセスを許可するにはここをクリックしてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop에 대한 로컬 네트워크 액세스를 거부했습니다. 이 권한 없이는 QuickDrop이 작동할 수 없습니다. 로컬 네트워크 액세스를 허용하려면 여기를 클릭하세요."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anda menolak akses rangkaian setempat untuk QuickDrop. QuickDrop tidak dapat berfungsi tanpa kebenaran ini. Klik di sini untuk memberikan akses rangkaian setempat."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du nektet tilgang til lokalt nettverk for QuickDrop. QuickDrop kan ikke fungere uten denne tillatelsen. Klikk her for å gi tilgang til lokalt nettverk."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Je hebt toegang tot het lokale netwerk voor QuickDrop geweigerd. QuickDrop kan niet werken zonder deze toestemming. Klik hier om toegang tot het lokale netwerk te verlenen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Odmówiłeś dostępu do lokalnej sieci dla QuickDrop. QuickDrop nie może działać bez tego uprawnienia. Kliknij tutaj, aby udzielić dostępu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você negou o acesso à rede local para o QuickDrop. O QuickDrop não pode funcionar sem essa permissão. Clique aqui para conceder acesso à rede local."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Negou o acesso à rede local para o QuickDrop. O QuickDrop não pode funcionar sem esta permissão. Clique aqui para conceder acesso à rede local."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ați refuzat accesul la rețeaua locală pentru QuickDrop. QuickDrop nu poate funcționa fără această permisiune. Apăsați aici pentru a oferi acces la rețeaua locală."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вы отклонили доступ QuickDrop к локальной сети. QuickDrop не может работать без этого разрешения. Нажмите здесь, чтобы предоставить доступ к локальной сети."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du nekade lokalen nätverksåtkomst för QuickDrop. QuickDrop kan inte fungera utan denna behörighet. Klicka här för att ge lokalen nätverksåtkomst."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "คุณปฏิเสธการเข้าถึงเครือข่ายท้องถิ่นสำหรับ QuickDrop. QuickDrop ไม่สามารถทำงานได้โดยปราศจากสิทธิ์นี้. คลิกที่นี่เพื่ออนุญาตการเข้าถึงเครือข่ายท้องถิ่น."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop için yerel ağ erişimine izin vermediniz. QuickDrop bu izin olmadan çalışmaz. Yerel ağ erişimine izin vermek için buraya tıklayın."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ви відхилили доступ до локальної мережі для QuickDrop. QuickDrop не може працювати без цього дозволу. Натисніть тут, щоб надати доступ до локальної мережі."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bạn đã từ chối quyền truy cập mạng cục bộ cho QuickDrop. QuickDrop không thể hoạt động nếu không có quyền này. Nhấp vào đây để cấp quyền."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您已拒绝QuickDrop的本地网络访问权限。QuickDrop无法在没有该权限的情况下工作。点击此处授予本地网络访问权限。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您已拒絕為 QuickDrop 授予本地網路訪問權限。QuickDrop 無法在沒有此許可的情況下運作。點擊這裡授予本地網路訪問權限。"
          }
        }
      }
    },
