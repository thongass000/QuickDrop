    "AutomaticallyAcceptFilesFooter" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يُوصى بتمكين هذا الإعداد فقط في شبكتك الخاصة. يمكن لأي شخص على نفس الشبكة إرسال الملفات إلى جهازك دون موافقتك."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Activar aquesta configuració només es recomana a la teva xarxa privada. Qualsevol persona a la mateixa xarxa podrà enviar arxius al teu dispositiu sense el teu consentiment."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Povolte toto nastavení pouze v soukromé síti. Každý na stejné síti může odesílat soubory na vaše zařízení bez vašeho souhlasu."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Det anbefales kun at aktivere denne indstilling på dit private netværk. Enhver på samme netværk kan sende filer til din enhed uden din tilladelse."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diese Einstellung wird nur in privaten Netzwerken empfohlen. Jede Person im selben Netzwerk kann ohne deine Zustimmung Dateien an diesen Mac senden."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Η ενεργοποίηση αυτής της ρύθμισης συνιστάται μόνο στο ιδιωτικό σας δίκτυο. Οποιοσδήποτε βρίσκεται στο ίδιο δίκτυο μπορεί να στείλει αρχεία στη συσκευή σας χωρίς τη συγκατάθεσή σας."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enabling this setting is only recommended in your private network. Anyone on the same network can send files to your device without your consent."
          }
        },
        "en-AU" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enable this only on private networks – others can send files freely."
          }
        },
        "en-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enable this only on private networks to let anyone on the network send files without approval."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enabling this setting is only advised for private networks. Anyone on the same network can send files to your device without your approval."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se recomienda habilitar esta opción solo en su red privada. Cualquier persona en la misma red puede enviar archivos a su dispositivo sin su consentimiento."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Habilitar esta configuración solo se recomienda en tu red privada. Cualquiera en la misma red puede enviar archivos a tu dispositivo sin tu consentimiento."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Suosittelemme tämän asetuksen käyttöä vain omassa yksityisessä verkossasi. Verkossasi olevat voivat lähettää tiedostoja sinun laitteellesi ilman lupaasi."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'activation de ce paramètre est recommandée uniquement sur votre réseau privé. Toute personne sur le même réseau peut envoyer des fichiers sur votre appareil sans votre consentement."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Activer ce paramètre est seulement recommandé sur votre réseau privé. Toute personne sur le même réseau peut envoyer des fichiers à votre appareil sans votre consentement."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "הפעלת הגדרה זו מומלצת רק ברשת הפרטית שלך. כל אדם באותה רשת יוכל לשלוח קבצים למכשיר שלך ללא הסכמתך."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "इस सेटिंग को सक्षम करना केवल आपके निजी नेटवर्क में ही अनुशंसित है। एक ही नेटवर्क पर कोई भी व्यक्ति आपकी सहमति के बिना आपकी डिवाइस पर फ़ाइलें भेज सकता है।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Omogućivanje ove postavke preporučuje se samo u vašoj privatnoj mreži. Svatko na istoj mreži može slati datoteke na vaš uređaj bez vašeg pristanka."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ennek a beállításnak az engedélyezése csak a saját privát hálózatán ajánlott. Bárki a hálózaton belül fájlokat küldhet az eszközére az ön beleegyezése nélkül."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mengaktifkan pengaturan ini hanya disarankan di jaringan pribadi Anda. Siapa pun di jaringan yang sama dapat mengirim file ke perangkat Anda tanpa persetujuan Anda."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'abilitazione di questa impostazione è consigliata solo nella tua rete privata. Chiunque nella stessa rete può inviare file al tuo dispositivo senza il tuo consenso."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "この設定はプライベートネットワークでのみ有効にすることを推奨します。同じネットワーク上の誰でも、あなたの許可なしにファイルを送信できる可能性があります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 설정은 개인 네트워크에서만 활성화하는 것이 좋습니다. 같은 네트워크에 있는 누구나 사용자의 동의 없이 파일을 보낼 수 있습니다."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mengaktifkan tetapan ini hanya disyorkan dalam rangkaian peribadi anda. Sesiapa sahaja dalam rangkaian yang sama boleh menghantar fail ke peranti anda tanpa kebenaran anda."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Det anbefales kun å aktivere denne innstillingen på private nettverk. Alle på samme nettverk kan sende filer til enheten din uten ditt samtykke."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Het inschakelen van deze instelling wordt alleen aanbevolen in uw privé-netwerk. Iedereen in hetzelfde netwerk kan bestanden naar uw apparaat sturen zonder uw toestemming."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Włączenie tego ustawienia jest zalecane tylko w sieci prywatnej. Każdy w tej samej sieci może wysłać pliki na Twoje urządzenie bez zgody."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ativar esta configuração é recomendado apenas na sua rede privada. Qualquer pessoa na mesma rede pode enviar arquivos para o seu dispositivo sem o seu consentimento."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ativar esta definição é recomendado apenas na sua rede privada. Qualquer pessoa na mesma rede pode enviar ficheiros para o seu dispositivo sem o seu consentimento."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Activarea acestei opțiuni este recomandată doar în rețeaua privată. Oricine din aceeași rețea poate trimite fișiere către dispozitivul dvs. fără consimțământ."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Включение этой настройки рекомендуется только в вашей частной сети. Любой пользователь в той же сети может отправлять файлы на ваше устройство без вашего согласия."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Att aktivera den här inställningen rekommenderas endast i ditt privata nätverk. Alla på samma nätverk kan skicka filer till din enhet utan ditt samtycke."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "แนะนำให้เปิดใช้งานการตั้งค่านี้เฉพาะในเครือข่ายส่วนตัวของคุณเท่านั้น ใครก็ตามที่อยู่ในเครือข่ายเดียวกันสามารถส่งไฟล์ไปยังอุปกรณ์ของคุณได้โดยไม่ต้องได้รับอนุญาต"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu ayarın etkinleştirilmesi yalnızca özel ağınızda önerilir. Aynı ağda olan herkes cihazınıza dosya gönderebilir."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Увімкнення цього параметра рекомендується лише у вашій приватній мережі. Будь-хто в тій самій мережі може надсилати файли на ваш пристрій без вашої згоди."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Việc bật cài đặt này chỉ nên áp dụng cho mạng riêng tư. bất kỳ ai cùng mạng đều có thể gửi tệp đến thiết bị của bạn mà không cần sự đồng ý."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "仅建议在您的私人网络中启用此设置。同一网络中的任何人都可以在未经您同意的情况下向您的设备发送文件。"
          }
