        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop не зміг визначити адресу вашого маршрутизатора. Будь ласка, зверніться до інструкції користувача вашого Wi-Fi маршрутизатора, щоб дізнатися її."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
