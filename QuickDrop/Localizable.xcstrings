      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "قد لا يسمح جهاز التوجيه الخاص بك بالتواصل بين الأجهزة"
          }
        },
