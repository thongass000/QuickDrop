    "TimeoutDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تعذر على QuickDrop الاتصال بهاتفك. يرجى فتح إعدادات جهاز Android والبحث عن 'Quick Share'. قم بتغيير الإعداد 'من يمكنه المشاركة معك' إلى 'الجميع' ثم حاول مرة أخرى."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop no s'ha pogut connectar al teu telèfon. Si us plau, obre la configuració del teu dispositiu Android i cerca 'Quick Share'. Canvia la configuració 'Qui pot compartir amb tu' a 'Tothom' i torna-ho a provar."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop se nemohl připojit k vašemu telefonu. Otevřete prosím nastavení vašeho zařízení Android a vyhledejte 'Quick Share'. Změňte nastavení 'Kdo může sdílet s vámi' na 'Všichni' a zkuste to znovu."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop kunne ikke forbinde til din telefon. Åbn indstillingerne på din Android-enhed, søg efter 'Quick Share'. Ændr indstillingen 'Hvem kan dele med dig' til 'Alle' og prøv igen."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop konnte keine Verbindung zu deinem Telefon herstellen. Öffne die Einstellungen deines Android-Geräts und suche nach 'Quick Share'. Ändere die Einstellung 'Wer kann mit dir teilen' auf 'Jeder' und versuche es erneut."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Το QuickDrop δεν μπόρεσε να συνδεθεί με το τηλέφωνό σας. Ανοίξτε τις ρυθμίσεις της συσκευής Android σας και αναζητήστε 'Quick Share'. Αλλάξτε τη ρύθμιση 'Ποιος μπορεί να μοιράζεται μαζί σας' σε 'Όλοι' και δοκιμάστε ξανά."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop could not connect to your phone. Please open the settings of your Android device and search for 'Quick Share'. Change the setting 'Who can share with you' to 'Everyone', and try again."
          }
        },
        "en-AU" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop couldn't reach your Android. Open Android's 'Quick Share' settings, set 'Who can share with you' to 'Everyone' and retry."
          }
        },
        "en-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop couldn’t connect to your phone. Open your Android settings, search \"Quick Share,\" set 'Who can share with you' to 'Everyone,' then retry."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop couldn't connect to your phone. Set 'Who can share with you' in your Android's 'Quick Share' settings to 'Everyone' and retry."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop no pudo conectarse a tu teléfono. Abre la configuración de tu dispositivo Android y busca 'Quick Share'. Cambia la opción 'Quién puede compartir contigo' a 'Todos' y vuelve a intentarlo."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop no pudo conectarse a tu teléfono. Por favor, abre la configuración de tu dispositivo Android y busca 'Quick Share'. Cambia la configuración de 'Quién puede compartir contigo' a 'Todos' e inténtalo de nuevo."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop ei voinut muodostaa yhteyttä puhelimeesi. Avaa Android-laitteesi asetukset ja etsi 'Quick Share'. Vaihda 'Kuka voi jakaa sinulle' -asetukseksi 'Kaikki' ja yritä uudelleen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop n’a pas pu se connecter à votre téléphone. Ouvrez les paramètres de votre appareil Android et recherchez 'Quick Share'. Modifiez le paramètre 'Qui peut partager avec vous' sur 'Tout le monde', puis réessayez."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop n'a pas pu se connecter à votre téléphone. Veuillez ouvrir les paramètres de votre appareil Android et rechercher \"Partage rapide\". Changez le paramètre 'Qui peut partager avec vous' à 'Tout le monde', puis réessayez."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop לא הצליח להתחבר לטלפון שלך. פתח את הגדרות מכשיר ה-Android שלך וחפש 'Quick Share'. שנה את ההגדרה 'מי יכול לשתף איתך' ל'כולם', ונסה שוב."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop आपके फोन से कनेक्ट नहीं हो सका। कृपया अपने Android डिवाइस के सेटिंग्स खोलें और 'Quick Share' खोजें। \"आपके साथ कौन शेयर कर सकता है\" सेटिंग को 'सभी के लिए' बदलें, और पुनः प्रयास करें।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop se nije mogao povezati s vašim telefonom. Otvorite postavke svog Android uređaja i potražite 'Quick Share'. Promijenite postavku 'Tko može dijeliti s vama' na 'Svi' i pokušajte ponovno."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A QuickDrop nem tudott csatlakozni a telefonodhoz. Nyisd meg az Android beállításait, és keresd meg a 'Quick Share' beállítást. Állítsd át a 'Ki oszthat meg veled' opciót 'Mindenki'-re, majd próbáld újra."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop tidak dapat terhubung ke ponsel Anda. Harap buka pengaturan perangkat Android Anda dan cari 'Quick Share'. Ubah pengaturan 'Siapa yang dapat berbagi dengan Anda' menjadi 'Semua orang', lalu coba lagi."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop non è riuscito a connettersi al tuo telefono. Apri le impostazioni del tuo dispositivo Android e cerca 'Quick Share'. Cambia l'impostazione 'Chi può condividere con te' su 'Tutti' e riprova."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDropが電話に接続できませんでした。Androidの設定を開き、「クイックシェア」を検索してください。「誰が共有できるか」の設定を「全員」に変更し、再度試してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop이 휴대전화에 연결할 수 없습니다. Android 설정을 열고 '퀵 공유'를 검색하세요. '누가 나와 공유할 수 있나요?' 설정을 '모두'로 변경하고 다시 시도하세요."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop gagal menyambungkan telefon anda. Sila buka tetapan peranti Android anda dan cari 'Kongsi Pantas'. Tukar tetapan 'Siapa yang boleh berkongsi dengan anda' kepada 'Semua orang', dan cuba lagi."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop kunne ikke koble til telefonen din. Åpne innstillingene til Android-enheten din og søk etter 'Quick Share'. Endre innstillingen 'Hvem kan dele med deg' til 'Alle' og prøv igjen."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop kon geen verbinding maken met je telefoon. Open de instellingen van je Android-apparaat en zoek naar 'Quick Share'. Wijzig de instelling 'Wie kan met je delen' naar 'Iedereen' en probeer het opnieuw."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop nie mógł połączyć się z telefonem. Otwórz ustawienia urządzenia z Androidem i wyszukaj ‚Quick Share‘. Zmień ustawienie ‚Kto może udostępniać‘ na ‚Wszyscy‘ i spróbuj ponownie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O QuickDrop não conseguiu se conectar ao seu telefone. Abra as configurações do seu dispositivo Android e procure por 'Quick Share'. Altere a configuração 'Quem pode compartilhar com você' para 'Todos' e tente novamente."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O QuickDrop não conseguiu ligar-se ao seu telefone. Abra as definições do seu dispositivo Android e procure por 'Quick Share'. Altere a definição 'Quem pode partilhar consigo' para 'Todos' e tente novamente."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop nu a reușit să se conecteze la telefonul tău. Deschide setările dispozitivului Android și caută 'Quick Share'. Schimbă setarea 'Cine poate partaja cu tine' pe 'Toată lumea' și încearcă din nou."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop не удалось подключиться к вашему телефону. Откройте настройки Android и найдите 'Quick Share'. Измените параметр 'Кто может делиться с вами' на 'Все' и попробуйте снова."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop kunde inte ansluta till din telefon. Öppna inställningarna på din Android-enhet och sök efter 'Quick Share'. Ändra inställningen 'Vem kan dela med dig' till 'Alla', och försök igen."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop ไม่สามารถเชื่อมต่อกับโทรศัพท์ของคุณได้ โปรดเปิดการตั้งค่าของอุปกรณ์ Android และค้นหา 'Quick Share' จากนั้นเปลี่ยนการตั้งค่า 'ใครสามารถแชร์กับคุณ' เป็น 'ทุกคน' และลองใหม่อีกครั้ง"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop telefonunuza bağlanamadı. Lütfen Android cihazınızın ayarlarını açın ve 'Quick Share'i arayın. 'Sizinle kim paylaşabilir' ayarını 'Herkes' olarak değiştirin ve yeniden deneyin."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop не вдалося підключитися до вашого телефону. Відкрийте налаштування Android і знайдіть 'Quick Share'. Змініть параметр 'Хто може ділитися з вами' на 'Усі' і спробуйте знову."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop không thể kết nối với điện thoại của bạn. Vui lòng mở cài đặt thiết bị Android và tìm \"Chia sẻ nhanh\". Thay đổi cài đặt 'Ai có thể chia sẻ với bạn' thành 'Mọi người', và thử lại."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop 无法连接到您的手机。请打开 Android 设备的设置并搜索“快速分享”（Quick Share）。将“谁可以与您分享”更改为“所有人”，然后重试。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop 無法連接到您的手機。請打開 Android 設置並搜索“快速共享”。將“誰可以與您共享”設定更改為“所有人”，然後重試。"
          }
        }
      }
    },
