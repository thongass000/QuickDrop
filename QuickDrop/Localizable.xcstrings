    "plusview_description" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "افتح QuickDrop+ لمتابعة تبادل الملفات بدون حدود. جميع الميزات الحالية والمستقبلية مشمولة، بالإضافة إلى تطبيقات iOS وAndroid."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desbloca QuickDrop+ per continuar intercanviant arxius sense límits. Inclou totes les funcions actuals i futures, a més de les apps per a iOS i Android."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Odemkněte QuickDrop+, abyste mohli nadále vyměňovat soubory bez omezení. Zahrnuty jsou všechny současné i budoucí funkce, stejně jako aplikace pro iOS a Android."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lås QuickDrop+ op for at fortsætte filudveksling uden begrænsninger. Alle nuværende og fremtidige funktioner er inkluderet, samt iOS- og Android-apps."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schalte QuickDrop+ frei, um Dateien unbegrenzt weiter auszutauschen. Alle aktuellen und zukünftigen Funktionen sowie die iOS- und Android-Apps sind enthalten."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ξεκλειδώστε το QuickDrop+ για να συνεχίσετε να ανταλλάσσετε αρχεία χωρίς περιορισμούς. Περιλαμβάνονται όλα τα τρέχοντα και μελλοντικά χαρακτηριστικά, καθώς και οι εφαρμογές iOS και Android."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unlock QuickDrop+ to continue exchanging files without limits. All current and future features are included, plus the iOS and Android apps."
          }
        },
        "en-AU" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unlock QuickDrop+ to continue exchanging files without limits. All current and future features are included, plus the iOS and Android apps."
          }
        },
        "en-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unlock QuickDrop+ to continue exchanging files without limits. All current and future features are included, plus the iOS and Android apps."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unlock QuickDrop+ to continue exchanging files without limits. All current and future features are included, plus the iOS and Android apps."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desbloquea QuickDrop+ para seguir compartiendo archivos sin límites. Incluye todas las funciones actuales y futuras, además de las apps para iOS y Android."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desbloquea QuickDrop+ para seguir intercambiando archivos sin límites. Incluye todas las funciones actuales y futuras, además de las apps para iOS y Android."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Avaa QuickDrop+, jotta voit jatkaa tiedostojen vaihtoa ilman rajoituksia. Kaikki nykyiset ja tulevat ominaisuudet sekä iOS- ja Android-sovellukset sisältyvät hintaan."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Débloquez QuickDrop+ pour continuer à échanger des fichiers sans limites. Toutes les fonctionnalités actuelles et futures sont incluses, ainsi que les applications iOS et Android."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Débloquez QuickDrop+ pour continuer à échanger des fichiers sans limites. Toutes les fonctions actuelles et futures sont incluses, ainsi que les applications iOS et Android."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "הפעל את QuickDrop+ כדי להמשיך להחליף קבצים ללא הגבלה. כל הפיצ’רים הנוכחיים והעתידיים כלולים, כולל אפליקציות iOS ואנדרואיד."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop+ अनलॉक करें ताकि आप बिना किसी सीमा के फाइलों का आदान-प्रदान जारी रख सकें। सभी वर्तमान और भविष्य की विशेषताएँ शामिल हैं, साथ ही iOS और Android ऐप्स भी।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Otključajte QuickDrop+ za neograničenu razmjenu datoteka. Svi trenutačni i budući sadržaji su uključeni, uz iOS i Android aplikacije."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oldja fel a QuickDrop+ szolgáltatást, hogy korlátlanul küldhessen és fogadhasson fájlokat. Minden jelenlegi és jövőbeli funkció, valamint az iOS és Android alkalmazások is benne vannak."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Buka QuickDrop+ untuk terus bertukar file tanpa batas. Semua fitur sekarang dan mendatang termasuk, beserta aplikasi iOS dan Android."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sblocca QuickDrop+ per continuare a scambiare file senza limiti. Tutte le funzionalità attuali e future sono incluse, oltre alle app iOS e Android."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop+ をアンロックして、無制限にファイル交換を続けましょう。現在および今後のすべての機能、さらに iOS と Android アプリが含まれます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop+를 잠금 해제하여 파일을 무제한으로 주고받으세요. 현재 및 향후 모든 기능과 iOS, Android 앱 이용이 포함됩니다."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Buka kunci QuickDrop+ untuk terus bertukar fail tanpa had. Semua ciri semasa dan akan datang disertakan, termasuk aplikasi iOS dan Android."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lås opp QuickDrop+ for å fortsette å utveksle filer uten begrensninger. Alle nåværende og fremtidige funksjoner er inkludert, samt iOS- og Android-appene."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ontgrendel QuickDrop+ om onbeperkt bestanden te blijven uitwisselen. Alle huidige en toekomstige functies, plus de iOS- en Android-apps zijn inbegrepen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Odblokuj QuickDrop+, aby dalej wymieniać pliki bez ograniczeń. Otrzymasz wszystkie obecne i przyszłe funkcje oraz aplikacje na iOS i Androida."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desbloqueie o QuickDrop+ para continuar trocando arquivos sem limites. Todos os recursos atuais e futuros estão incluídos, além dos apps para iOS e Android."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desbloqueie o QuickDrop+ para continuar a trocar ficheiros sem limites. Inclui todas as funcionalidades atuais e futuras, além das apps para iOS e Android."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deblochează QuickDrop+ pentru a continua transferul de fișiere fără limite. Toate funcțiile actuale și viitoare sunt incluse, plus aplicațiile iOS și Android."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Разблокируйте QuickDrop+, чтобы и дальше обмениваться файлами без ограничений. Все текущие и будущие функции, а также приложения для iOS и Android включены."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lås upp QuickDrop+ för att fortsätta utbyta filer utan begränsningar. Alla nuvarande och framtida funktioner ingår, samt appar för iOS och Android."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ปลดล็อก QuickDrop+ เพื่อส่งไฟล์ได้ไม่จำกัด รวมฟีเจอร์ปัจจุบันและอนาคต พร้อมแอป iOS และ Android"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sınırsız dosya alışverişi için QuickDrop+’ı açın. Mevcut ve gelecek tüm özellikler ile iOS ve Android uygulamaları dahildir."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Відкрийте QuickDrop+, щоб без обмежень обмінюватися файлами. Усі поточні й майбутні функції включено, а також додатки для iOS і Android."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mở khóa QuickDrop+ để tiếp tục chia sẻ tệp không giới hạn. Bao gồm tất cả tính năng hiện tại và sắp tới, cùng với ứng dụng iOS và Android."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "解锁 QuickDrop+，即可无限制传输文件。包含当前及未来所有功能，并支持 iOS 和 Android 应用。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "解鎖 QuickDrop+，即可無限傳輸檔案。包含所有現有和未來功能，還有 iOS 與 Android 應用程式。"
          }
        }
      }
    },
