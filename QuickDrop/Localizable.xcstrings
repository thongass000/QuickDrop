    "Error.Signature" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "توقيع غير صالح. عادةً ما يعني هذا أن الرسالة تعرضت للتلف أثناء النقل. يرجى المحاولة مرة أخرى."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ungültige Signatur. Dies bedeutet normalerweise, dass eine Nachricht während der Übertragung beschädigt wurde. Bitte versuche es erneut."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Invalid signature. This usually means that a message was damaged during transit. Please try again."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Firma no válida. Esto usualmente significa que un mensaje fue dañado durante el tránsito. Por favor, inténtelo de nuevo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Signature invalide. Cela signifie généralement qu'un message a été endommagé pendant le transit. Veuillez réessayer."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Érvénytelen aláírás. Ez általában azt jelenti, hogy egy üzenet sérült meg az átvitel során. Kérjük, próbálja újra."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Firma non valida. Questo di solito significa che un messaggio è stato danneggiato durante la trasmissione. Per favore riprova."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "署名が無効です。これは通常、メッセージが転送中に破損したことを意味します。もう一度試してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "잘못된 서명입니다. 보통은 전송 중 메시지가 손상된 것을 의미합니다. 다시 시도해 주세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ongeldige handtekening. Dit betekent meestal dat een bericht beschadigd is tijdens de overdracht. Probeer het opnieuw."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Assinatura inválida. Isso geralmente significa que uma mensagem foi danificada durante a transmissão. Por favor, tente novamente."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Assinatura inválida. Isso geralmente significa que uma mensagem foi danificada durante o trânsito. Por favor, tente novamente."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Semnătură nevalidă. De obicei, asta înseamnă că un mesaj a fost deteriorat în timpul transmiterii. Vă rugăm să încercați din nou."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Недействительная подпись. Обычно это означает, что сообщение было повреждено во время передачи. Пожалуйста, попробуйте еще раз."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ลายเซ็นไม่ถูกต้อง ซึ่งมักหมายถึงข้อความได้รับความเสียหายระหว่างการส่ง กรุณาลองใหม่อีกครั้ง"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Недійсний підпис. Зазвичай це означає, що повідомлення було пошкоджене під час передачі. Будь ласка, спробуйте ще раз."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "签名无效。这通常意味着消息在传输过程中损坏。请再试一次。"
          }
        }
      }
    },
    "FirewallDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اكتشف QuickDrop أن جدار الحماية قد يمنع جهاز Android الخاص بك من الاتصال بجهاز Mac الخاص بك. يتم استخدام جدران الحماية لحظر الاتصالات الواردة بشكل افتراضي. لتلقي الملفات، يجب السماح بالاتصالات الواردة، حيث يحاول هاتفك الاتصال بجهاز Mac – مما يُنشئ اتصالاً وارداً.\n\nمن المحتمل أنك تستخدم برنامج مكافحة فيروسات على جهاز Mac الخاص بك. لديك خياران:\n\n1. السماح بالاتصالات الواردة لتطبيق QuickDrop في إعدادات جدار الحماية الخاص بك. تختلف هذه العملية حسب البرنامج، لذلك قد تحتاج إلى التواصل مع الشركة المصنعة لبرنامج الحماية/جدار الحماية لمعرفة كيفية المتابعة.\n\n2. تعطيل جدار الحماية الخاص ببرنامج مكافحة الفيروسات واستخدام جدار الحماية المدمج في نظام macOS. جدار الحماية الخاص بـ Apple مُحسَّن لتطبيق QuickDrop.\n\nإليك كيفية تعطيل جدار الحماية لبرنامج مكافحة الفيروسات: افتح إعدادات النظام على جهاز Mac، وانتقل إلى الشبكة > VPN والتصفية، ثم قم بإيقاف تشغيل مرشح المحتوى. بعد ذلك، انتقل إلى الشبكة > جدار الحماية، وقم بتفعيل جدار الحماية الخاص بـ Mac.\n\nبعد القيام بذلك، سيتمكن هاتفك من الاتصال بجهاز Mac."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop hat festgestellt, dass eine Firewall möglicherweise verhindert, dass sich dein Android-Gerät mit deinem Mac verbinden kann. Firewalls blockieren standardmäßig eingehende Verbindungen. Um Dateien zu empfangen, müssen eingehende Verbindungen erlaubt sein, da dein Telefon versucht, eine Verbindung zu deinem Mac herzustellen – was eine eingehende Verbindung darstellt.\n\nWahrscheinlich verwendest du ein Antivirenprogramm auf deinem Mac. Du hast zwei Optionen:\n\n1. Erlaube eingehende Verbindungen für QuickDrop in deinen Firewall-Einstellungen. Dieses Verfahren variiert je nach Programm, daher solltest du den Hersteller deiner Firewall-/Antivirensoftware kontaktieren, um zu erfahren, wie dies durchgeführt werden kann.\n\n2. Deaktiviere die Firewall deiner Antivirensoftware und verwende stattdessen die integrierte Firewall des Mac. Die Firewall von Apple ist für QuickDrop optimiert.\n\nSo deaktivierst du die Firewall deiner Antivirensoftware: Öffne die Systemeinstellungen auf deinem Mac, navigiere zu Netzwerk > VPN & Filter und deaktiviere den Inhaltsfilter. Gehe dann zu Netzwerk > Firewall und aktiviere die Firewall des Mac.\n\nSobald dies erledigt ist, kann sich dein Telefon mit deinem Mac verbinden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop has detected that a firewall might prevent that your Android device can connect to your Mac. Firewalls are used to block incoming connections per default. For receiving files, it is required that incoming connections are allowed. This is because your phone tries to connect to your Mac – creating an incoming connection.\n\nYou most likely use an antivirus program on your Mac. You have two options:\n\n1.    Allow incoming connections for QuickDrop in your firewall settings. This procedure varies with every program, so you may have to ask the manufacturer of your firewall/antivirus software how this can be done.\n\n2.    Disable the firewall of your antivirus software, and use the Mac's inbuilt firewall instead. Apple's firewall is optimized for QuickDrop.\n\nHere’s how to disable the firewall of your antivirus program: Open System Settings on your Mac, navigate to Network > VPN & Filter, and disable the content filter. Then, navigate to Network > Firewall and click the toggle to enable the Mac's firewall.\n\nOnce this is done, your phone will be able to connect to your Mac."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop ha detectado que un firewall podría impedir que tu dispositivo Android se conecte a tu Mac. Los firewalls se utilizan para bloquear conexiones entrantes por defecto. Para recibir archivos, es necesario permitir las conexiones entrantes, ya que tu teléfono intenta conectarse a tu Mac, creando una conexión entrante.\n\nEs probable que utilices un programa antivirus en tu Mac. Tienes dos opciones:\n\n1. Permitir conexiones entrantes para QuickDrop en la configuración de tu firewall. Este procedimiento varía según el programa, por lo que es posible que debas consultar al fabricante de tu software de firewall/antivirus para saber cómo hacerlo.\n\n2. Desactivar el firewall de tu software antivirus y utilizar en su lugar el firewall integrado del Mac. El firewall de Apple está optimizado para QuickDrop.\n\nAsí es como se desactiva el firewall de tu programa antivirus: Abre Configuración del Sistema en tu Mac, navega a Red > VPN y Filtro, y desactiva el filtro de contenido. Luego, ve a Red > Firewall y activa el firewall del Mac.\n\nUna vez hecho esto, tu teléfono podrá conectarse a tu Mac."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop a détecté qu'un pare-feu pourrait empêcher votre appareil Android de se connecter à votre Mac. Les pare-feu bloquent par défaut les connexions entrantes. Pour recevoir des fichiers, vous devez autoriser les connexions entrantes, car votre téléphone tente de se connecter à votre Mac – créant ainsi une connexion entrante.\n\nIl est probable que vous utilisiez un programme antivirus sur votre Mac. Vous avez deux options :\n\n1. Autoriser les connexions entrantes pour QuickDrop dans les paramètres de votre pare-feu. Cette procédure varie selon le programme, vous devrez donc peut-être contacter le fabricant de votre logiciel de pare-feu/antivirus pour savoir comment procéder.\n\n2. Désactiver le pare-feu de votre logiciel antivirus et utiliser le pare-feu intégré du Mac. Le pare-feu d'Apple est optimisé pour QuickDrop.\n\nVoici comment désactiver le pare-feu de votre programme antivirus : Ouvrez les Réglages Système sur votre Mac, allez dans Réseau > VPN et Filtrage, puis désactivez le filtre de contenu. Ensuite, allez dans Réseau > Pare-feu et activez le pare-feu du Mac.\n\nUne fois cela fait, votre téléphone pourra se connecter à votre Mac."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A QuickDrop észlelte, hogy egy tűzfal megakadályozhatja, hogy Android-eszköze csatlakozzon a Mac számítógépéhez. A tűzfalak alapértelmezés szerint blokkolják a bejövő kapcsolatokat. A fájlok fogadásához engedélyezni kell a bejövő kapcsolatokat, mivel a telefonja megpróbál csatlakozni a Mac-hez – vagyis bejövő kapcsolatot kezdeményez.\n\nValószínűleg vírusvédelmi programot használ a Mac-en. Két lehetősége van:\n\n1. Engedélyezze a bejövő kapcsolatokat a QuickDrop számára a tűzfal beállításaiban. Ez az eljárás programonként eltérhet, ezért szükség lehet arra, hogy kapcsolatba lépjen a tűzfalat vagy vírusirtót gyártó céggel a pontos útmutatásért.\n\n2. Tiltsa le a vírusirtó szoftver tűzfalát, és használja a macOS beépített tűzfalát. Az Apple tűzfala optimalizálva van a QuickDrop használatához.\n\nÍgy kapcsolhatja ki a vírusirtó tűzfalát: Nyissa meg a Rendszerbeállításokat a Mac-en, menjen a Hálózat > VPN és Szűrés menüpontra, és kapcsolja ki a tartalomszűrőt. Ezután menjen a Hálózat > Tűzfal részhez, és kapcsolja be a Mac tűzfalát.\n\nEzek után a telefonja csatlakozni tud majd a Mac-hez."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop ha rilevato che un firewall potrebbe impedire al tuo dispositivo Android di connettersi al tuo Mac. I firewall sono utilizzati per bloccare le connessioni in entrata per impostazione predefinita. Per ricevere file, è necessario che le connessioni in entrata siano consentite. Questo perché il tuo telefono tenta di connettersi al tuo Mac, creando una connessione in entrata.\n\nÈ probabile che tu stia utilizzando un programma antivirus sul tuo Mac. Hai due opzioni:\n\n1. Consenti le connessioni in entrata per QuickDrop nelle impostazioni del tuo firewall. Questa procedura varia a seconda del programma, quindi potresti dover contattare il produttore del tuo software firewall/antivirus per sapere come procedere.\n\n2. Disattiva il firewall del tuo software antivirus e utilizza invece il firewall integrato del Mac. Il firewall di Apple è ottimizzato per QuickDrop.\n\nEcco come disattivare il firewall del tuo programma antivirus: Apri le Impostazioni di Sistema sul tuo Mac, vai su Rete > VPN e Filtro, e disattiva il filtro dei contenuti. Poi, vai su Rete > Firewall e attiva il firewall del Mac.\n\nUna volta fatto ciò, il tuo telefono sarà in grado di connettersi al tuo Mac."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDropは、ファイアウォールがAndroidデバイスのMacへの接続を妨げる可能性があることを検出しました。ファイアウォールはデフォルトで受信接続をブロックします。ファイルを受信するには、受信接続を許可する必要があります。これは、電話がMacに接続しようとするためで、受信接続を作成します。\n\nおそらく、Macでウイルス対策プログラムを使用しています。2つのオプションがあります：\n\n1. ファイアウォール設定でQuickDropの受信接続を許可します。この手順はプログラムによって異なるため、ファイアウォール/ウイルス対策ソフトウェアの製造元に方法を問い合わせる必要があります。\n\n2. ウイルス対策ソフトウェアのファイアウォールを無効にし、代わりにMacの内蔵ファイアウォールを使用します。AppleのファイアウォールはQuickDropに最適化されています。\n\nウイルス対策プログラムのファイアウォールを無効にする方法は次のとおりです：Macでシステム設定を開き、ネットワーク > VPNとフィルターに移動し、コンテンツフィルターを無効にします。次に、ネットワーク > ファイアウォールに移動し、Macのファイアウォールを有効にします。\n\nこれが完了すると、電話はMacに接続できるようになります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop은 방화벽이 Android 기기가 Mac에 연결하는 것을 방해할 수 있음을 감지했습니다. 방화벽은 기본적으로 수신 연결을 차단합니다. 파일을 수신하려면 수신 연결을 허용해야 합니다. 이는 휴대폰이 Mac에 연결하려고 시도하기 때문입니다 – 수신 연결을 생성합니다.\n\nMac에서 바이러스 백신 프로그램을 사용하고 있을 가능성이 높습니다. 두 가지 옵션이 있습니다:\n\n1. 방화벽 설정에서 QuickDrop에 대한 수신 연결을 허용하십시오. 이 절차는 프로그램마다 다르므로 방화벽/바이러스 백신 소프트웨어 제조업체에 문의하여 방법을 알아보십시오.\n\n2. 바이러스 백신 소프트웨어의 방화벽을 비활성화하고 대신 Mac의 내장 방화벽을 사용하십시오. Apple의 방화벽은 QuickDrop에 최적화되어 있습니다.\n\n바이러스 백신 프로그램의 방화벽을 비활성화하는 방법은 다음과 같습니다: Mac에서 시스템 설정을 열고 네트워크 > VPN 및 필터로 이동하여 콘텐츠 필터를 비활성화합니다. 그런 다음 네트워크 > 방화벽으로 이동하여 Mac의 방화벽을 활성화합니다.\n\n이 작업이 완료되면 휴대폰이 Mac에 연결할 수 있습니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop heeft vastgesteld dat een firewall mogelijk verhindert dat je Android-apparaat verbinding maakt met je Mac. Firewalls worden standaard gebruikt om inkomende verbindingen te blokkeren. Om bestanden te ontvangen, moeten inkomende verbindingen worden toegestaan, omdat je telefoon probeert verbinding te maken met je Mac – wat een inkomende verbinding creëert.\n\nJe gebruikt waarschijnlijk een antivirusprogramma op je Mac. Je hebt twee opties:\n\n1. Sta inkomende verbindingen toe voor QuickDrop in je firewallinstellingen. Deze procedure varieert per programma, dus je moet mogelijk de fabrikant van je firewall-/antivirussoftware raadplegen over hoe dit moet worden gedaan.\n\n2. Schakel de firewall van je antivirussoftware uit en gebruik in plaats daarvan de ingebouwde firewall van de Mac. De firewall van Apple is geoptimaliseerd voor QuickDrop.\n\nZo schakel je de firewall van je antivirusprogramma uit: Open Systeeminstellingen op je Mac, navigeer naar Netwerk > VPN en Filter, en schakel het inhoudsfilter uit. Ga vervolgens naar Netwerk > Firewall en schakel de firewall van de Mac in.\n\nZodra dit is gedaan, kan je telefoon verbinding maken met je Mac."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O QuickDrop detectou que um firewall pode impedir que seu dispositivo Android se conecte ao seu Mac. Firewalls são usados para bloquear conexões de entrada por padrão. Para receber arquivos, é necessário permitir conexões de entrada, pois seu telefone tenta se conectar ao seu Mac – criando uma conexão de entrada.\n\nÉ provável que você esteja usando um programa antivírus no seu Mac. Você tem duas opções:\n\n1. Permitir conexões de entrada para o QuickDrop nas configurações do seu firewall. Esse procedimento varia de acordo com o programa, portanto, você pode precisar consultar o fabricante do seu software de firewall/antivírus sobre como fazer isso.\n\n2. Desativar o firewall do seu software antivírus e usar o firewall integrado do Mac. O firewall da Apple é otimizado para o QuickDrop.\n\nVeja como desativar o firewall do seu programa antivírus: Abra as Configurações do Sistema no seu Mac, vá para Rede > VPN e Filtro, e desative o filtro de conteúdo. Em seguida, vá para Rede > Firewall e ative o firewall do Mac.\n\nDepois de feito isso, seu telefone poderá se conectar ao seu Mac."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O QuickDrop detectou que um firewall pode impedir que o seu dispositivo Android se conecte ao seu Mac. Os firewalls são utilizados para bloquear conexões de entrada por padrão. Para receber ficheiros, é necessário permitir conexões de entrada, pois o seu telefone tenta conectar-se ao seu Mac – criando uma conexão de entrada.\n\nÉ provável que esteja a utilizar um programa antivírus no seu Mac. Tem duas opções:\n\n1. Permitir conexões de entrada para o QuickDrop nas configurações do seu firewall. Este procedimento varia conforme o programa, pelo que poderá ter de contactar o fabricante do seu software de firewall/antivírus para saber como proceder.\n\n2. Desativar o firewall do seu software antivírus e utilizar o firewall incorporado do Mac. O firewall da Apple está otimizado para o QuickDrop.\n\nVeja como desativar o firewall do seu programa antivírus: Abra as Definições do Sistema no seu Mac, navegue até Rede > VPN e Filtro, e desative o filtro de conteúdo. Em seguida, vá até Rede > Firewall e ative o firewall do Mac.\n\nDepois de feito isto, o seu telefone poderá conectar-se ao seu Mac."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop a detectat că un firewall poate împiedica dispozitivul Android să se conecteze la Mac-ul dvs. Firewall-urile sunt utilizate pentru a bloca implicit conexiunile de intrare. Pentru a primi fișiere, trebuie să permiteți conexiunile de intrare, deoarece telefonul dvs. încearcă să se conecteze la Mac – creând o conexiune de intrare.\n\nEste probabil să utilizați un program antivirus pe Mac. Aveți două opțiuni:\n\n1. Permiteți conexiunile de intrare pentru QuickDrop în setările firewall-ului dvs. Procedura variază în funcție de program, așa că poate fi necesar să contactați producătorul software-ului de firewall/antivirus pentru instrucțiuni.\n\n2. Dezactivați firewall-ul din software-ul antivirus și utilizați firewall-ul integrat din macOS. Firewall-ul Apple este optimizat pentru QuickDrop.\n\nIată cum puteți dezactiva firewall-ul programului antivirus: Deschideți Setările Sistemului pe Mac, mergeți la Rețea > VPN și Filtrare, apoi dezactivați filtrul de conținut. Apoi mergeți la Rețea > Firewall și activați firewall-ul de pe Mac.\n\nDupă ce faceți acest lucru, telefonul dvs. va putea să se conecteze la Mac."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop обнаружил, что брандмауэр может препятствовать подключению вашего устройства Android к вашему Mac. Брандмауэры по умолчанию блокируют входящие подключения. Для получения файлов необходимо разрешить входящие подключения, поскольку ваш телефон пытается подключиться к вашему Mac, создавая входящее соединение.\n\nСкорее всего, вы используете антивирусную программу на вашем Mac. У вас есть два варианта:\n\n1. Разрешите входящие подключения для QuickDrop в настройках вашего брандмауэра. Эта процедура различается в зависимости от программы, поэтому вам, возможно, придется обратиться к производителю вашего программного обеспечения брандмауэра/антивируса за инструкциями.\n\n2. Отключите брандмауэр вашего антивирусного программного обеспечения и используйте встроенный брандмауэр Mac. Брандмауэр Apple оптимизирован для QuickDrop.\n\nВот как отключить брандмауэр вашего антивирусного программного обеспечения: Откройте Системные настройки на вашем Mac, перейдите в Сеть > VPN и Фильтр, и отключите фильтр содержимого. Затем перейдите в Сеть > Брандмауэр и включите брандмауэр Mac.\n\nПосле этого ваш телефон сможет подключиться к вашему Mac."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop ตรวจพบว่าไฟร์วอลล์อาจป้องกันไม่ให้อุปกรณ์ Android ของคุณเชื่อมต่อกับ Mac ของคุณ โดยปกติไฟร์วอลล์จะบล็อกการเชื่อมต่อขาเข้าตามค่าเริ่มต้น ในการรับไฟล์ จำเป็นต้องอนุญาตการเชื่อมต่อขาเข้า เนื่องจากโทรศัพท์ของคุณพยายามเชื่อมต่อกับ Mac ของคุณ ซึ่งเป็นการสร้างการเชื่อมต่อขาเข้า\n\nคุณอาจใช้โปรแกรมป้องกันไวรัสบน Mac ของคุณ คุณมีสองตัวเลือก:\n\n1. อนุญาตการเชื่อมต่อขาเข้าสำหรับ QuickDrop ในการตั้งค่าไฟร์วอลล์ของคุณ ขั้นตอนนี้แตกต่างกันไปในแต่ละโปรแกรม ดังนั้นคุณอาจต้องสอบถามผู้ผลิตซอฟต์แวร์ไฟร์วอลล์/ป้องกันไวรัสของคุณว่าทำได้อย่างไร\n\n2. ปิดใช้งานไฟร์วอลล์ของซอฟต์แวร์ป้องกันไวรัสของคุณ และใช้ไฟร์วอลล์ในตัวของ Mac แทน ไฟร์วอลล์ของ Apple ได้รับการปรับแต่งให้เหมาะสมสำหรับ QuickDrop\n\nวิธีปิดใช้งานไฟร์วอลล์ของโปรแกรมป้องกันไวรัสของคุณ: เปิดการตั้งค่าระบบบน Mac ของคุณ ไปที่ เครือข่าย > VPN และตัวกรอง และปิดใช้งานตัวกรองเนื้อหา จากนั้นไปที่ เครือข่าย > ไฟร์วอลล์ และเปิดใช้งานไฟร์วอลล์ของ Mac\n\nเมื่อเสร็จสิ้น โทรศัพท์ของคุณจะสามารถเชื่อมต่อกับ Mac ของคุณได้"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop виявив, що брандмауер може заважати підключенню вашого пристрою Android до вашого Mac. Брандмауери за замовчуванням блокують вхідні з'єднання. Щоб отримувати файли, необхідно дозволити вхідні з'єднання, оскільки ваш телефон намагається підключитися до вашого Mac – створюючи вхідне з'єднання.\n\nЙмовірно, ви використовуєте антивірусну програму на вашому Mac. У вас є два варіанти:\n\n1. Дозвольте вхідні з'єднання для QuickDrop у налаштуваннях брандмауера. Ця процедура відрізняється залежно від програми, тому вам, можливо, доведеться звернутися до виробника вашого програмного забезпечення брандмауера/антивірусу, щоб дізнатися, як це зробити.\n\n2. Вимкніть брандмауер вашого антивірусного програмного забезпечення та використовуйте вбудований брандмауер Mac. Брандмауер Apple оптимізований для QuickDrop.\n\nОсь як вимкнути брандмауер вашої антивірусної програми: Відкрийте Системні налаштування на вашому Mac, перейдіть до Мережа > VPN і Фільтр, і вимкніть фільтр вмісту. Потім перейдіть до Мережа > Брандмауер і увімкніть брандмауер Mac.\n\nПісля цього ваш телефон зможе підключитися до вашого Mac."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QuickDrop 检测到防火墙可能会阻止您的 Android 设备连接到您的 Mac。防火墙默认用于阻止传入连接。为了接收文件，必须允许传入连接，因为您的手机尝试连接到您的 Mac – 创建一个传入连接。\n\n您很可能在 Mac 上使用了防病毒程序。您有两个选项：\n\n1. 在防火墙设置中允许 QuickDrop 的传入连接。此过程因程序而异，因此您可能需要咨询防火墙/防病毒软件制造商，了解如何操作。\n\n2. 禁用防病毒软件的防火墙，改用 Mac 的内置防火墙。Apple 的防火墙针对 QuickDrop 进行了优化。\n\n以下是禁用防病毒程序防火墙的方法：在 Mac 上打开系统设置，导航到网络 > VPN 和过滤器，禁用内容过滤器。然后，导航到网络 > 防火墙，点击切换以启用 Mac 的防火墙。\n\n完成后，您的手机将能够连接到您的 Mac。"
          }
        }
      }
    },
