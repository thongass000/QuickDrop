    "introduction_enable_share_extension_not_visible_answer" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "إذا لم يظهر امتداد المشاركة في إعدادات النظام، يرجى إعادة تشغيل جهاز Mac والمحاولة مرة أخرى. أو بدلاً من ذلك، اضغط على \"تخطي\" لتفعيل الامتداد لاحقًا."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si l'extensió de compartició no és visible als Ajustos del sistema, reinicia el teu Mac i torna-ho a provar. Alternativament, fes clic a “Omet” per activar l'extensió més tard."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pokud sdílecí rozšíření není viditelné v Systémovém nastavení, restartujte prosím svůj Mac a zkuste to znovu. Případně klikněte na „Přeskočit“ pro aktivaci rozšíření později."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hvis delingsudvidelsen ikke er synlig i Systemindstillinger, så genstart din Mac og prøv igen. Alternativt kan du klikke på “Spring over” for at aktivere udvidelsen senere."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn die Freigabe-Erweiterung in den Systemeinstellungen nicht sichtbar ist, starte bitte deinen Mac neu und versuche es erneut. Alternativ kannst du auf „Überspringen“ klicken, um die Erweiterung später zu aktivieren."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Αν η επέκταση κοινοποίησης δεν εμφανίζεται στις Ρυθμίσεις Συστήματος, κάντε επανεκκίνηση του Mac σας και δοκιμάστε ξανά. Εναλλακτικά, κάντε κλικ στο «Παράλειψη» για να την ενεργοποιήσετε αργότερα."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If the share extension is not visible in System Settings, please restart your Mac and try again. Alternatively, click on “Skip” to enable the extension later."
          }
        },
        "en-AU" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If the share extension isn’t visible in System Settings, please restart your Mac and try again. Alternatively, click on “Skip” to enable the extension later."
          }
        },
        "en-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If the share extension isn’t visible in System Settings, please restart your Mac and try again. Alternatively, click on “Skip” to enable the extension later."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If the share extension is not visible in System Settings, please restart your Mac and try again. Alternatively, click on “Skip” to enable the extension later."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si la extensión para compartir no aparece en Configuración del sistema, reinicia tu Mac e inténtalo de nuevo. Alternativamente, haz clic en \"Omitir\" para activar la extensión más tarde."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si la extensión para compartir no es visible en Configuración del sistema, reinicia tu Mac y vuelve a intentarlo. Alternativamente, haz clic en “Omitir” para activar la extensión más tarde."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jos jakolaajennus ei näy Järjestelmäasetuksissa, käynnistä Mac uudelleen ja yritä uudestaan. Vaihtoehtoisesti voit klikata \"Ohita\" ottaaksesi laajennuksen käyttöön myöhemmin."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si l’extension de partage n’est pas visible dans les Réglages Système, veuillez redémarrer votre Mac et réessayez. Sinon, cliquez sur « Ignorer » pour activer l’extension plus tard."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si l’extension de partage n’apparaît pas dans les Réglages système, veuillez redémarrer votre Mac et réessayez. Vous pouvez aussi cliquer sur « Passer » pour activer l’extension plus tard."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "אם ההרחבה לא מופיעה בהגדרות המערכת, נא להפעיל את ה-Mac מחדש ולנסות שוב. לחלופין, לחץ על \"דלג\" כדי להפעיל את ההרחבה מאוחר יותר."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अगर सिस्टम सेटिंग्स में शेयर एक्सटेंशन दिखाई नहीं दे रहा है, तो कृपया अपने Mac को रीस्टार्ट करें और फिर से प्रयास करें। वैकल्पिक रूप से, बाद में एक्सटेंशन सक्रिय करने के लिए \"छोड़ें\" पर क्लिक करें।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ako dijeljena ekstenzija nije vidljiva u Postavkama sustava, ponovno pokrenite svoj Mac i pokušajte ponovno. Alternativno, kliknite na „Preskoči” kako biste omogućili ekstenziju kasnije."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ha a megosztási kiterjesztés nem látható a Rendszerbeállításokban, indítsd újra a Mac-et, majd próbáld újra. Alternatívaként kattints a „Kihagyás” gombra, hogy később engedélyezd a kiterjesztést."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jika ekstensi berbagi tidak terlihat di Pengaturan Sistem, silakan mulai ulang Mac Anda dan coba lagi. Atau, klik “Lewati” untuk mengaktifkan ekstensi nanti."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se l'estensione di condivisione non è visibile nelle Impostazioni di Sistema, riavvia il Mac e riprova. In alternativa, fai clic su “Salta” per attivare l'estensione in seguito."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "共有拡張機能がシステム設定に表示されない場合は、Macを再起動し、再度お試しください。もしくは「スキップ」をクリックして後で拡張機能を有効にすることもできます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "시스템 설정에서 공유 확장 기능이 보이지 않는 경우, Mac을 다시 시작한 후 다시 시도해 주세요. 또는 “건너뛰기”를 클릭하여 나중에 확장 기능을 활성화할 수 있습니다."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jika sambungan perkongsian tidak kelihatan dalam Tetapan Sistem, sila mulakan semula Mac anda dan cuba lagi. Atau, klik \"Langkau\" untuk membolehkan sambungan kemudian."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hvis delingsutvidelsen ikke er synlig i Systeminnstillinger, vennligst start Macen på nytt og prøv igjen. Alternativt kan du klikke på «Hopp over» for å aktivere utvidelsen senere."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Als de deel-extensie niet zichtbaar is in de Systeeminstellingen, herstart dan je Mac en probeer het opnieuw. Of klik op “Overslaan” om de extensie later in te schakelen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jeśli rozszerzenie udostępniania nie jest widoczne w Ustawieniach systemowych, uruchom ponownie Maca i spróbuj ponownie. Możesz też kliknąć „Pomiń”, aby włączyć rozszerzenie później."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se a extensão de compartilhamento não estiver visível nas Configurações do Sistema, reinicie seu Mac e tente novamente. Como alternativa, clique em “Pular” para ativar a extensão depois."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se a extensão de partilha não aparecer nas Definições do Sistema, reinicie o seu Mac e tente novamente. Em alternativa, clique em “Saltar” para ativar a extensão mais tarde."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dacă extensia de partajare nu este vizibilă în Configurările de Sistem, reporniți Mac-ul și încercați din nou. Alternativ, faceți clic pe „Sari peste” pentru a activa extensia mai târziu."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Если расширение не отображается в Системных настройках, перезагрузите Mac и попробуйте снова. Или нажмите «Пропустить», чтобы включить расширение позже."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Om delningstillägget inte är synligt i Systeminställningar, starta om din Mac och försök igen. Alternativt, klicka på ”Hoppa över” för att aktivera tillägget senare."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "หากไม่พบส่วนขยายในการตั้งค่าระบบ กรุณารีสตาร์ท Mac ของคุณแล้วลองใหม่ หรือคลิก \"ข้าม\" เพื่อเปิดใช้ส่วนขยายในภายหลัง"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Paylaşım uzantısı Sistem Ayarlarında görünmüyorsa, lütfen Mac'inizi yeniden başlatıp tekrar deneyin. Alternatif olarak, uzantıyı daha sonra etkinleştirmek için \"Atla\"ya tıklayın."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Якщо розширення для спільного доступу не видно в Системних налаштуваннях, перезавантажте Mac і спробуйте ще раз. Або натисніть «Пропустити», щоб увімкнути розширення пізніше."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nếu tiện ích chia sẻ không hiển thị trong Cài đặt Hệ thống, vui lòng khởi động lại Mac và thử lại. Hoặc bấm vào “Bỏ qua” để bật tiện ích này sau."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果在系统设置中看不到共享扩展，请重启您的 Mac 后重试。或者，点击“跳过”稍后启用扩展。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果在系統設定中看不到分享擴充功能，請重新啟動您的 Mac 並再試一次。或者，點擊「跳過」以稍後啟用該擴充功能。"
          }
        }
      }
    },
    "introduction_enable_share_extension_skip_message" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "إذا لم تقم بتفعيل إضافة المشاركة، ستظل قادرًا على استقبال الملفات على هذا الجهاز. ومع ذلك، لا يمكنك إرسال الملفات حتى تفعيل إضافة المشاركة. يمكنك تفعيلها لاحقًا في أي وقت."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si no actives l'extensió de compartició, igualment pots rebre fitxers en aquest Mac. Tanmateix, no podràs enviar fitxers fins que activis l'extensió de compartició. Pots fer-ho més endavant en qualsevol moment."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pokud nerozšíříte sdílení, budete stále moci přijímat soubory na tomto Macu. Soubory však nebude možné odesílat, dokud sdílení nepovolíte. Můžete to udělat kdykoli později."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hvis du ikke aktiverer delingsudvidelsen, kan du stadig modtage filer på denne Mac. Du kan dog ikke sende filer, før du aktiverer delingsudvidelsen. Du kan gøre det senere når som helst."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn du die Share-Erweiterung nicht aktivierst, kannst du auf diesem Mac trotzdem Dateien empfangen. Allerdings kannst du keine Dateien senden, bis die Share-Erweiterung aktiviert ist. Das kannst du jederzeit später nachholen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Αν δεν ενεργοποιήσετε την επέκταση κοινοποίησης, μπορείτε ακόμα να λαμβάνετε αρχεία σε αυτό το Mac. Ωστόσο, δεν μπορείτε να στέλνετε αρχεία μέχρι να ενεργοποιήσετε την επέκταση. Μπορείτε να το κάνετε και αργότερα οποιαδήποτε στιγμή."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If you do not enable the share extension, you are still able to receive files on this Mac. However, you cannot send files until you enable the share extension. You can do so later at any time."
          }
        },
        "en-AU" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If you do not enable the share extension, you are still able to receive files on this Mac. However, you cannot send files until you enable the share extension. You can do so later at any time."
          }
        },
        "en-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If you do not enable the share extension, you are still able to receive files on this Mac. However, you cannot send files until you enable the share extension. You can do so later at any time."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If you do not enable the share extension, you are still able to receive files on this Mac. However, you cannot send files until you enable the share extension. You can do so later at any time."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si no habilitas la extensión para compartir, aún puedes recibir archivos en este Mac. Sin embargo, no podrás enviar archivos hasta que lo hagas. Puedes habilitarla más tarde en cualquier momento."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si no habilitas la extensión de compartición, aún puedes recibir archivos en esta Mac. Sin embargo, no podrás enviar archivos hasta que la habilites. Puedes hacerlo más tarde cuando quieras."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jos et ota jakolaajennusta käyttöön, voit silti vastaanottaa tiedostoja tällä Macilla. Et kuitenkaan voi lähettää tiedostoja ennen kuin otat jakolaajennuksen käyttöön. Voit tehdä sen myöhemmin milloin tahansa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si vous n’activez pas l’extension de partage, vous pouvez tout de même recevoir des fichiers sur ce Mac. Cependant, vous ne pourrez pas envoyer de fichiers tant que l’extension n’est pas activée. Vous pourrez le faire à tout moment ultérieurement."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si vous n’activez pas l’extension de partage, vous pourrez quand même recevoir des fichiers sur ce Mac. Cependant, vous ne pourrez pas envoyer de fichiers tant que l’extension de partage n’est pas activée. Vous pouvez l’activer plus tard, en tout temps."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "אם לא תפעיל את סיומת השיתוף, עדיין תוכל לקבל קבצים במחשב הזה. עם זאת, לא תוכל לשלוח קבצים עד שתפעיל את הסיומת. תוכל לעשות זאת מאוחר יותר בכל עת."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अगर आप शेयर एक्सटेंशन सक्रिय नहीं करते, तो भी आप इस Mac पर फाइलें प्राप्त कर सकते हैं। हालांकि, आप फाइलें भेज नहीं सकते जब तक शेयर एक्सटेंशन सक्रिय नहीं करते। आप यह बाद में कभी भी कर सकते हैं।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ako ne omogućite proširenje za dijeljenje, i dalje možete primati datoteke na ovom Macu. Međutim, ne možete slati datoteke dok ne omogućite proširenje za dijeljenje. To možete učiniti kasnije u bilo kojem trenutku."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ha nem engedélyezi a megosztási bővítményt, ezen a Mac-en még fogadhat fájlokat. Fájlokat azonban csak akkor küldhet, ha engedélyezi a megosztási bővítményt. Ezt később bármikor megteheti."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jika Anda tidak mengaktifkan ekstensi berbagi, Anda tetap dapat menerima file di Mac ini. Namun, Anda tidak dapat mengirim file sebelum mengaktifkan ekstensi berbagi. Anda bisa melakukannya nanti kapan saja."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se non abiliti l'estensione di condivisione, puoi comunque ricevere file su questo Mac. Tuttavia, non puoi inviare file finché non abiliti l'estensione. Puoi farlo anche in seguito, in qualsiasi momento."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "共有拡張機能を有効にしなくても、このMacでファイルの受信は可能です。ただし、拡張機能が有効になるまでファイルの送信はできません。後でいつでも設定できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "공유 확장 기능을 활성화하지 않아도 이 Mac에서 파일을 받을 수 있습니다. 그러나 공유 확장 기능을 활성화하지 않으면 파일을 보낼 수 없습니다. 언제든지 나중에 활성화할 수 있습니다."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jika anda tidak aktifkan sambungan perkongsian, anda masih boleh menerima fail di Mac ini. Namun, anda tidak boleh menghantar fail sehingga anda aktifkan sambungan perkongsian. Anda boleh lakukannya kemudian pada bila-bila masa."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hvis du ikke aktiverer deleutvidelsen, kan du fortsatt motta filer på denne Macen. Men du kan ikke sende filer før du har aktivert deleutvidelsen. Du kan gjøre det når som helst senere."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Als je de deel-extensie niet inschakelt, kun je nog steeds bestanden ontvangen op deze Mac. Je kunt echter geen bestanden verzenden totdat je de deel-extensie inschakelt. Dit kun je later op elk moment doen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jeśli nie włączysz rozszerzenia udostępniania, nadal możesz odbierać pliki na tym Macu. Jednak nie możesz wysyłać plików, dopóki nie włączysz tego rozszerzenia. Możesz to zrobić później w dowolnym momencie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se você não ativar a extensão de compartilhamento, ainda poderá receber arquivos neste Mac. No entanto, não poderá enviar arquivos até ativar a extensão. Você pode fazer isso a qualquer momento depois."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se não ativar a extensão de partilha, poderá receber ficheiros neste Mac. No entanto, não pode enviar ficheiros até ativar a extensão de partilha. Pode fazê-lo mais tarde a qualquer momento."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dacă nu activezi extensia de partajare, poți primi în continuare fișiere pe acest Mac. Totuși, nu poți trimite fișiere până nu activezi extensia de partajare. Poți face acest lucru oricând mai târziu."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Если не включить расширение для обмена, вы всё равно сможете получать файлы на этом Mac. Однако отправлять файлы вы не сможете до тех пор, пока не включите это расширение. Включить его можно в любое время."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Om du inte aktiverar delningstillägget kan du fortfarande ta emot filer på denna Mac. Men du kan inte skicka filer förrän du har aktiverat delningstillägget. Du kan göra det senare när som helst."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "หากคุณไม่ได้เปิดส่วนขยายแชร์ คุณยังสามารถรับไฟล์บน Mac นี้ได้ แต่จะไม่สามารถส่งไฟล์ได้จนกว่าจะเปิดใช้งาน คุณสามารถตั้งค่าได้ในภายหลัง"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Paylaşım uzantısını etkinleştirmezseniz, bu Mac'te dosya alabilirsiniz. Ancak paylaşım uzantısını açana kadar dosya gönderemezsiniz. Daha sonra istediğiniz zaman etkinleştirebilirsiniz."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Якщо ви не увімкнете розширення для обміну, зможете тільки отримувати файли на цьому Mac. Надсилати файли можна буде лише після увімкнення цього розширення. Ви можете зробити це пізніше у будь-який час."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nếu bạn không bật tiện ích chia sẻ, bạn vẫn có thể nhận tệp trên máy Mac này. Tuy nhiên, bạn không thể gửi tệp cho đến khi bật tiện ích chia sẻ. Bạn có thể bật bất cứ lúc nào sau đó."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果你没有启用共享扩展，仍然可以在这台 Mac 上接收文件。但在启用共享扩展前，无法发送文件。你可以随时在之后启用。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果你沒有啟用分享擴充功能，仍然可以在這台 Mac 上接收檔案，但無法傳送檔案，直到你啟用分享擴充功能為止。你可以隨時稍後再啟用。"
          }
        }
      }
    },
