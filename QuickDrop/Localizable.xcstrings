    "NoLocalNetworkAccessDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لقد رفضت وصول الشبكة المحلية لتطبيق QuickDrop. لا يمكن لتطبيق QuickDrop العمل بدون هذا الإذن. انقر هنا لمنح الوصول إلى الشبكة المحلية."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Has denegat l'accés a la xarxa local per QuickDrop. QuickDrop no pot funcionar sense aquest permís. Fes clic aquí per concedir l'accés a la xarxa local."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Odvolali jste přístup QuickDropu k místní síti. QuickDrop nemůže fungovat bez tohoto oprávnění. Klikněte sem pro udělení přístupu k místní síti."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du har nægtet lokal netværksadgang til QuickDrop. QuickDrop kan ikke fungere uden denne tilladelse. Klik her for at give adgang til det lokale netværk."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du hast den lokalen Netzwerkzugriff für QuickDrop verweigert. QuickDrop kann ohne diese Berechtigung nicht funktionieren. Klicke hier, um den lokalen Netzwerkzugriff zu gewähren."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Απορρίψατε την πρόσβαση στο τοπικό δίκτυο για το QuickDrop. Το QuickDrop δεν μπορεί να λειτουργήσει χωρίς αυτή την άδεια. Πατήστε εδώ για να χορηγήσετε πρόσβαση στο τοπικό δίκτυο."
          }
