    "RemoveTrustedDeviceAlertDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "إذا قمت بإزالة هذا الجهاز، يجب قبول النقل الوارد من هذا الجهاز يدويًا."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si elimines aquest dispositiu, les transferències entrants d'aquest dispositiu s'hauran d'acceptar manualment."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pokud toto zařízení odstraníte, příchozí přenosy z něj bude nutné přijímat ručně."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hvis du fjerner denne enhed, skal indkommende overførsler fra denne enhed accepteres manuelt."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn Du dieses Gerät entfernst, müssen eingehende Übertragungen von diesem Gerät manuell akzeptiert werden."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Αν αφαιρέσετε αυτή τη συσκευή, οι εισερχόμενες μεταφορές αρχείων από αυτή θα πρέπει να γίνονται χειροκίνητα αποδεκτές."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If you remove this device, incoming transfers from this device have to be accepted manually."
          }
        },
        "en-AU" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Removing this means approval needed for future transfers."
          }
        },
        "en-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Removing this device means future transfers require manual approval."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Removing this device means its transfers require manual approval."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si eliminas este dispositivo, las transferencias entrantes de este dispositivo deberán aceptarse manualmente."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si eliminas este dispositivo, las transferencias entrantes de este dispositivo deberán ser aceptadas manualmente."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jos poistat tämän laitteen, tämän laitteen siirrot on hyväksyttävä manuaalisesti."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si vous retirez cet appareil, les transferts entrants devront être acceptés manuellement."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si vous supprimez cet appareil, les transferts entrants de cet appareil devront être acceptés manuellement."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "אם תסיר את המכשיר הזה, יש לקבל ידנית כל העברה נכנסת מהמכשיר הזה."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यदि आप इस डिवाइस को हटाते हैं, तो इस डिवाइस से आने वाले ट्रांसफर को मैन्युअल रूप से स्वीकार करना होगा।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ako uklonite ovaj uređaj, dolazne prijenose s ovog uređaja morat ćete prihvatiti ručno."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ha eltávolítja ezt az eszközt, az erről az eszközről érkező átviteleket manuálisan kell elfogadni."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jika Anda menghapus perangkat ini, transfer masuk dari perangkat ini harus diterima secara manual."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se rimuovi questo dispositivo, i trasferimenti in arrivo da questo dispositivo dovranno essere accettati manualmente."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このデバイスを削除すると、このデバイスからの受信転送は手動で受け入れる必要があります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 기기를 제거하면, 이 기기에서 오는 전송은 수동으로 승인이 필요합니다."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jika anda mengeluarkan peranti ini, pemindahan masuk dari peranti ini perlu diterima secara manual."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hvis du fjerner denne enheten, må innkommende overføringer fra denne enheten aksepteres manuelt."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Als u dit apparaat verwijdert, moeten binnenkomende overdrachten van dit apparaat handmatig worden geaccepteerd."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jeśli usuniesz to urządzenie, przychodzące transfery z tego urządzenia będą musiały być akceptowane ręcznie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se você remover este dispositivo, transferências recebidas dele precisarão ser aceitas manualmente."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se remover este dispositivo, as transferências recebidas deste dispositivo terão de ser aceites manualmente."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dacă elimini acest dispozitiv, transferurile primite de la acest dispozitiv trebuie acceptate manual."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Если вы удалите это устройство, входящие передачи с этого устройства придется принимать вручную."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Om du tar bort den här enheten måste inkommande överföringar från denna enhet accepteras manuellt."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "หากคุณลบอุปกรณ์นี้ การรับโอนย้ายข้อมูลจากอุปกรณ์นี้ต้องได้รับการยืนยันด้วยตนเอง"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu cihazı kaldırırsanız, bu cihazdan gelen transferler manuel olarak kabul edilmek zorunda kalır."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Якщо ви видалите цей пристрій, вхідні передачі з цього пристрою доведеться приймати вручну."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nếu bạn xóa thiết bị này, việc chuyển giao từ thiết bị này sẽ phải được chấp nhận thủ công."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果您移除此设备，此设备的传入传输必须手动接受。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "移除此裝置後，來自此裝置的傳輸需手動接受。"
          }
        }
      }
    },
