    "introduction_local_network_access_skip_message" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "افتح إعدادات النظام، ثم انتقل إلى \"الخصوصية والأمان\" > \"الشبكة المحلية\". تأكد من تفعيل QuickDrop، ثم تابع.\n\nوإلا، فلن يعمل QuickDrop بشكل صحيح."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Obre la Configuració del sistema i ves a «Privadesa i seguretat» > «Xarxa local». Assegura't que QuickDrop està activat i després continua.\n\nEn cas contrari, QuickDrop no funcionarà correctament."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Otevřete Systémová nastavení a přejděte do \"Ochrana soukromí a zabezpečení\" > \"Místní síť\". Ujistěte se, že je QuickDrop povolen, a poté pokračujte.\n\nJinak nebude QuickDrop fungovat správně."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Åbn Systemindstillinger, og gå til \"Privatliv & Sikkerhed\" > \"Lokalt netværk\". Sørg for, at QuickDrop er aktiveret, og fortsæt derefter.\n\nEllers fungerer QuickDrop ikke korrekt."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Öffne die Systemeinstellungen und gehe zu „Datenschutz & Sicherheit“ > „Lokales Netzwerk“. Stelle sicher, dass QuickDrop aktiviert ist und fahre dann fort.\n\nAndernfalls funktioniert QuickDrop nicht richtig."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ανοίξτε τις Ρυθμίσεις Συστήματος και μεταβείτε στο \"Απόρρητο & Ασφάλεια\" > \"Τοπικό Δίκτυο\". Βεβαιωθείτε ότι το QuickDrop είναι ενεργοποιημένο και, στη συνέχεια, συνεχίστε.\n\nΔιαφορετικά, το QuickDrop δεν θα λειτουργεί σωστά."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Open System Settings, and go to \"Privacy & Security\" > \"Local Network\". Make sure that QuickDrop is enabled, then continue.\n\nOtherwise, QuickDrop will not work properly."
          }
        },
        "en-AU" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Open System Settings, and go to \"Privacy & Security\" > \"Local Network\". Make sure that QuickDrop is enabled, then continue.\n\nOtherwise, QuickDrop will not work properly."
          }
        },
        "en-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Open System Settings, then go to “Privacy & Security” > “Local Network.” Make sure that QuickDrop is enabled, then continue.\n\nOtherwise, QuickDrop will not work properly."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Open System Settings, and go to \"Privacy & Security\" > \"Local Network\". Make sure that QuickDrop is enabled, then continue.\n\nOtherwise, QuickDrop will not work properly."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abre Configuración del sistema y ve a \"Privacidad y seguridad\" > \"Red local\". Asegúrate de que QuickDrop está activado, luego continúa.\n\nDe lo contrario, QuickDrop no funcionará correctamente."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abre Configuración del sistema y ve a \"Privacidad y seguridad\" > \"Red local\". Asegúrate de que QuickDrop esté habilitado, luego continúa.\n\nDe lo contrario, QuickDrop no funcionará correctamente."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Avaa Järjestelmäasetukset ja siirry kohtaan \"Yksityisyys ja turvallisuus\" > \"Paikallinen verkko\". Varmista, että QuickDrop on käytössä, ja jatka sitten.\n\nMuuten QuickDrop ei toimi kunnolla."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ouvrez Réglages Système, puis allez dans « Confidentialité et sécurité » > « Réseau local ». Assurez-vous que QuickDrop est activé, puis continuez.\n\nSinon, QuickDrop ne fonctionnera pas correctement."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ouvrez les Réglages du système, puis allez à « Confidentialité et sécurité » > « Réseau local ». Assurez-vous que QuickDrop est activé, puis continuez.\n\nSinon, QuickDrop ne fonctionnera pas correctement."
          }
        },
        "he" : {
          "stringUnit" : {
