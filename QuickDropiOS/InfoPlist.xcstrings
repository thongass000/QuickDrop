        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cihazları algılamak ve dosya aktarmak için yerel ağa erişim gereklidir."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Доступ до локальної мережі потрібен для виявлення пристроїв та передавання файлів через вашу мережу Wi-Fi."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cần truy cập mạng nội bộ để phát hiện thiết bị và truyền tệp qua Wi-Fi của bạn."
